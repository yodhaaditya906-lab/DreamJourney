---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Savings Dashboard - DreamJourney">
    <main class="pt-20">
        <section class="py-16 bg-gray-50">
            <div class="container mx-auto px-4">
                <h2 class="text-3xl font-bold mb-10 text-center">📊 Your Savings Dashboard</h2>
                
                <!-- Balance Card -->
                <div class="max-w-4xl mx-auto bg-gradient-to-r from-primary to-secondary text-white p-8 rounded-xl shadow-lg mb-8">
                    <div class="flex flex-col md:flex-row justify-between items-center">
                        <div class="mb-4 md:mb-0">
                            <h3 class="font-bold text-xl opacity-90">DREAMWALLET BALANCE</h3>
                            <div class="text-4xl font-bold mt-2">Rp 8,450,000</div>
                        </div>
                        <button class="bg-white text-primary px-6 py-2 rounded-full font-bold hover:bg-gray-100 transition shadow-md cursor-pointer dashboard-action-btn">
                            Top Up Wallet
                        </button>
                    </div>
                </div>

                <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
                    <!-- Active Savings -->
                    <div class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
                        <h3 class="font-bold text-xl mb-6 flex items-center">
                            <i data-feather="target" class="mr-2 text-primary"></i> Active Goals
                        </h3>
                        
                        <div class="space-y-6">
                            <div>
                                <div class="flex justify-between mb-2">
                                    <span class="font-semibold text-gray-800">Bali Trip</span>
                                    <span class="text-primary font-bold">60%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-3">
                                    <div class="bg-primary h-3 rounded-full" style="width: 60%"></div>
                                </div>
                                <div class="flex justify-between mt-1 text-sm text-gray-500">
                                    <span>Rp 3,000,000 / 5,000,000</span>
                                    <span>2 months left</span>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between mb-2">
                                    <span class="font-semibold text-gray-800">Honeymoon</span>
                                    <span class="text-secondary font-bold">40%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-3">
                                    <div class="bg-secondary h-3 rounded-full" style="width: 40%"></div>
                                </div>
                                <div class="flex justify-between mt-1 text-sm text-gray-500">
                                    <span>Rp 8,000,000 / 20,000,000</span>
                                    <span>8 months left</span>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between mb-2">
                                    <span class="font-semibold text-gray-800">Japan Fund</span>
                                    <span class="text-accent font-bold">10%</span>
                                </div>
                                <div class="w-full bg-gray-200 rounded-full h-3">
                                    <div class="bg-accent h-3 rounded-full" style="width: 10%"></div>
                                </div>
                                <div class="flex justify-between mt-1 text-sm text-gray-500">
                                    <span>Rp 1,500,000 / 15,000,000</span>
                                    <span>12 months left</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Transactions -->
                    <div class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
                        <h3 class="font-bold text-xl mb-6 flex items-center">
                            <i data-feather="clock" class="mr-2 text-primary"></i> Recent Activity
                        </h3>
                        
                        <div class="space-y-4">
                            <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg transition">
                                <div class="flex items-center">
                                    <div class="bg-green-100 text-green-600 p-2 rounded-full mr-3">
                                        <i data-feather="arrow-up-right" class="w-4 h-4"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-gray-800">Top Up</p>
                                        <p class="text-xs text-gray-500">Today, 10:00 AM</p>
                                    </div>
                                </div>
                                <span class="text-green-600 font-bold">+ Rp 500,000</span>
                            </div>

                            <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg transition">
                                <div class="flex items-center">
                                    <div class="bg-blue-100 text-blue-600 p-2 rounded-full mr-3">
                                        <i data-feather="briefcase" class="w-4 h-4"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-gray-800">Allocated to Bali</p>
                                        <p class="text-xs text-gray-500">Yesterday</p>
                                    </div>
                                </div>
                                <span class="text-gray-600 font-bold">Rp 500,000</span>
                            </div>
                        </div>
                        
                        <button class="w-full mt-4 text-primary font-semibold text-sm hover:underline cursor-pointer dashboard-action-btn">
                            View All Transactions
                        </button>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const actionButtons = document.querySelectorAll('.dashboard-action-btn');
        actionButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                alert('This is a demo dashboard. Please login to your official account to access wallet actions.');
            });
        });
    });
</script>
