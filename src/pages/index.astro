import Layout from '../layouts/Layout.astro';

const { userId } = Astro.locals.auth();
const isLoggedIn = !!userId;

let packages = [];
try {
  const response = await fetch('https://docs.google.com/spreadsheets/d/1eD4zbqYsW-Ce6eLemIUt5VdSIykWnlhM0kwTVBgD1Yw/export?format=csv');
  const csvText = await response.text();
  
  const imageMap = {
    "bali": "https://images.unsplash.com/photo-1537996194471-e657df975ab4?q=80&w=600&auto=format&fit=crop",
    "jogja": "https://images.unsplash.com/photo-1626125345510-4603468eedfb?q=80&w=600&auto=format&fit=crop",
    "malioboro": "https://images.unsplash.com/photo-1626125345510-4603468eedfb?q=80&w=600&auto=format&fit=crop",
    "bandung": "https://images.unsplash.com/photo-1590559899147-eb54a69622df?q=80&w=600&auto=format&fit=crop",
    "puncak bogor": "https://images.unsplash.com/photo-1626082928503-4c91b5c4644d?q=80&w=600&auto=format&fit=crop",
    "malang": "https://images.unsplash.com/photo-1602167732001-97b7b137a1f5?q=80&w=600&auto=format&fit=crop",
    "gunung bromo": "https://images.unsplash.com/photo-1602167732001-97b7b137a1f5?q=80&w=600&auto=format&fit=crop",
    "surabaya": "https://images.unsplash.com/photo-1601999109332-542b18dbec57?q=80&w=600&auto=format&fit=crop",
    "pulau karimun jawa": "https://images.unsplash.com/photo-1516690561799-46d8f74f9abf?q=80&w=600&auto=format&fit=crop",
    "banda neira": "https://images.unsplash.com/photo-1516483638261-f4dbaf036963?q=80&w=600&auto=format&fit=crop",
    "raja ampat": "https://images.unsplash.com/photo-1544551763-46a013bb70d5?q=80&w=600&auto=format&fit=crop"
  };

  const defaultImage = "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=600&auto=format&fit=crop";

  function slugify(text) {
      if (!text) return '';
      return text.toString().toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^\w\-]+/g, '')
        .replace(/\-\-+/g, '-')
        .replace(/^-+/, '')
        .replace(/-+$/, '');
  }

  function parseCSVRow(row) {
      const result = [];
      let curVal = '';
      let inQuotes = false;
      for (let i = 0; i < row.length; i++) {
          if (row[i] === '"') {
              inQuotes = !inQuotes;
          } else if (row[i] === ',' && !inQuotes) {
              result.push(curVal.trim());
              curVal = '';
          } else {
              curVal += row[i];
          }
      }
      result.push(curVal.trim());
      return result;
  }

  const rows = csvText.split('\n').slice(1);
  packages = rows.filter(row => row.trim() && !row.startsWith(',')).map((row, index) => {
    const cols = parseCSVRow(row);
    
    const title = cols[0] || "Unknown";
    const desc = cols[1] || "";
    const dailyPrice = cols[2] || "";
    const rawDailyPrice = cols[2] ? cols[2].replace(/[^\d]/g, '') : "0";
    const parsedDailyPrice = parseInt(rawDailyPrice, 10) || 0;
    const rawPrice = cols[3] ? cols[3].replace(/[^\d]/g, '') : "0";
    const price = parseInt(rawPrice, 10) || 0;
    const time = cols[4] || "";
    const origin = cols[5] || "Unknown";
    const destination = cols[6] || title;
    
    let mainImage = cols[11] || defaultImage;
    if (mainImage && mainImage.startsWith('"')) mainImage = mainImage.substring(1, mainImage.length-1);
    
    const priceAkomodasi = parseInt(cols[16] ? cols[16].replace(/[^\d]/g, '') : "0", 10) || 0;
    const priceTransport = parseInt(cols[17] ? cols[17].replace(/[^\d]/g, '') : "0", 10) || 0;
    const priceWahana = parseInt(cols[18] ? cols[18].replace(/[^\d]/g, '') : "0", 10) || 0;
    const priceLainnya = parseInt(cols[19] ? cols[19].replace(/[^\d]/g, '') : "0", 10) || 0;
    
    return {
      title,
      slug: slugify(title),
      desc,
      dailyPrice,
      parsedDailyPrice,
      price,
      origin,
      destination,
      time,
      badge: index === 0 ? "Hot Deal" : (index === 1 ? "Best Seller" : ""),
      badgeColor: index === 0 ? "bg-red-500 text-white" : (index === 1 ? "bg-blue-500 text-white" : ""),
      image: mainImage,
      priceAkomodasi,
      priceTransport,
      priceWahana,
      priceLainnya
    };
  });
} catch (error) {
  console.error("Failed to fetch packages:", error);
}

// --- PROMO BANNER DATA FETCHING ---
let promos: any[] = [];
try {
  const promoRes = await fetch('https://docs.google.com/spreadsheets/d/1s3pSHYsAhMuCDKZBM92zfbWntqRm4_0ESdaG9rNEz0s/export?format=csv');
  const promoCsvText = await promoRes.text();
  
  function parseCSVRowLocal(row: string) {
      const result = [];
      let curVal = '';
      let inQuotes = false;
      for (let i = 0; i < row.length; i++) {
          if (row[i] === '"') {
              inQuotes = !inQuotes;
          } else if (row[i] === ',' && !inQuotes) {
              result.push(curVal.trim());
              curVal = '';
          } else {
              curVal += row[i];
          }
      }
      result.push(curVal.trim());
      return result;
  }

  const promoRows = promoCsvText.split('\n').slice(1);
  promos = promoRows.filter(row => row.trim() && !row.startsWith(',')).map((row, idx) => {
      const cols = parseCSVRowLocal(row);
      return {
          id: `promo-${idx}`,
          label: cols[0] || "Promo",
          title: cols[1] || "",
          desc: cols[2] || "",
          image: cols[3] || "/images/promo_banner_1.png",
          ctaText: cols[4] || "Klaim",
          ctaLink: cols[5] || "/packages"
      };
  });
} catch (error) {
  console.error("Failed to fetch promo data:", error);
}

// Fallback if empty
if (promos.length === 0) {
    promos = [
        {
            id: "promo-fallback",
            label: "Spesial Liburan",
            title: "Eksplorasi Keindahan Bali",
            desc: "Diskon hingga 30% untuk pemesanan minggu ini. Jangan sampai kehabisan!",
            image: "/images/promo_banner_1.png",
            ctaText: "Klaim Promo",
            ctaLink: "/packages"
        }
    ];
}
