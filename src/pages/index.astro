---
import Layout from '../layouts/Layout.astro';
---

<Layout title="DreamJourney - Smart Travel Financing">
    <main class="pt-20">
        <!-- Hero Section -->
        <section class="relative bg-gradient-to-r from-primary to-secondary text-white py-20">
            <div class="container mx-auto px-4">
                <div class="max-w-3xl mx-auto text-center">
                    <h1 class="text-4xl md:text-5xl font-bold mb-6">Travel Now, Pay Smart</h1>
                    <p class="text-xl mb-10">Book your dream vacation with flexible payment options - pay upfront, installment plans, or save gradually.</p>
                    <div class="flex flex-wrap justify-center gap-4">
                        <a href="/packages" class="bg-white text-primary px-8 py-3 rounded-full font-bold hover:bg-gray-100 transition shadow-md">Explore Packages</a>
                        <a href="/planner" class="border-2 border-white px-8 py-3 rounded-full font-bold hover:bg-white hover:text-primary transition shadow-md">Plan Your Trip</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Quick Access Grid -->
        <section class="py-16 bg-white">
            <div class="container mx-auto px-4">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Package Booking Card -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border-t-4 border-accent hover:shadow-xl transition">
                        <div class="text-primary mb-4">
                            <i data-feather="globe" class="w-10 h-10"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">Book Packages</h3>
                        <p class="text-gray-600 mb-4">Choose from 1000+ packages with installment options</p>
                        <a href="/packages" class="text-primary font-semibold flex items-center hover:underline">
                            Explore Packages <i data-feather="arrow-right" class="ml-2 w-4 h-4"></i>
                        </a>
                        <span class="inline-block mt-3 bg-red-100 text-red-800 text-xs px-2 py-1 rounded-full font-medium">Flash Sale!</span>
                    </div>

                    <!-- Custom Trip Card -->
                    <div class="bg-white rounded-xl shadow-lg p-6 border-t-4 border-secondary hover:shadow-xl transition">
                        <div class="text-secondary mb-4">
                            <i data-feather="map" class="w-10 h-10"></i>
                        </div>
                        <h3 class="text-xl font-bold mb-2">Custom Trip</h3>
                        <p class="text-gray-600 mb-4">Design your vacation matching your style & budget</p>
                        <a href="/planner" class="text-secondary font-semibold flex items-center hover:underline">
                            Plan Now <i data-feather="arrow-right" class="ml-2 w-4 h-4"></i>
                        </a>
                        <span class="inline-block mt-3 bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded-full font-medium">AI Recommendations</span>
                    </div>



                    <!-- Holiday Loan Card -->
                </div>
            </div>
        </section>

        <!-- Featured Packages Preview -->
        <section id="packages-preview" class="py-16 bg-gray-50">
            <div class="container mx-auto px-4">
                <div class="flex justify-between items-center mb-10">
                    <h2 class="text-3xl font-bold">🔥 Popular Packages This Week</h2>
                    <a href="/packages" class="text-primary font-semibold hover:underline">View All</a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Package 1 -->
                    <div class="package-item bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-red-200" data-destination="Bali" data-price="3450000" data-duration="4" data-popularity="12">
                        <div class="relative">
                            <img src="https://images.unsplash.com/photo-1537996194471-e657df975ab4?q=80&w=1938&auto=format&fit=crop" alt="Bali Package" class="w-full h-48 object-cover">
                            <span class="absolute top-2 right-2 bg-red-500 text-white text-xs px-2 py-1 rounded">Hot Deal</span>
                        </div>
                        <div class="p-5">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-lg">Bali - 4D3N</h3>
                                    <p class="text-gray-600 text-sm">4-star Hotel + Breakfast</p>
                                </div>
                                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">0% Installment</span>
                            </div>
                            
                            <div class="my-4">
                                <p class="text-gray-800 font-bold">Rp 19,166/day</p>
                                <p class="text-gray-600 text-sm">Price: Rp 3,450,000</p>
                                <p class="text-gray-600 text-sm">Countdown: 181 days</p>
                            </div>
                            
                            <div class="mb-4">
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-primary h-2 rounded-full" style="width: 75%"></div>
                                </div>
                                <p class="text-xs text-gray-600 mt-1">12 people saving for this package</p>
                            </div>
                            
                            <button class="w-full bg-primary hover:bg-primary-dark text-white py-2 rounded-lg font-semibold transition cursor-pointer start-saving-btn">
                                Start Saving
                            </button>
                        </div>
                    </div>

                    <!-- Package 2 -->
                    <div class="package-item bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition" data-destination="Japan" data-price="8900000" data-duration="5" data-popularity="8">
                        <div class="relative">
                            <img src="https://images.unsplash.com/photo-1524413840807-0c3cb6fa808d?q=80&w=2070&auto=format&fit=crop" alt="Japan Package" class="w-full h-48 object-cover">
                        </div>
                        <div class="p-5">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-lg">Japan - 5D4N</h3>
                                    <p class="text-gray-600 text-sm">3-star Hotel + Breakfast</p>
                                </div>
                                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">0% Installment</span>
                            </div>
                            
                            <div class="my-4">
                                <p class="text-gray-800 font-bold">Rp 24,722/day</p>
                                <p class="text-gray-600 text-sm">Price: Rp 8,900,000</p>
                                <p class="text-gray-600 text-sm">Countdown: 360 days</p>
                            </div>
                            
                            <div class="mb-4">
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-primary h-2 rounded-full" style="width: 45%"></div>
                                </div>
                                <p class="text-xs text-gray-600 mt-1">8 people saving for this package</p>
                            </div>
                            
                            <button class="w-full bg-primary hover:bg-primary-dark text-white py-2 rounded-lg font-semibold transition cursor-pointer start-saving-btn">
                                Start Saving
                            </button>
                        </div>
                    </div>

                    <!-- Package 3 -->
                    <div class="package-item bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-blue-200" data-destination="Europe" data-price="25000000" data-duration="10" data-popularity="5">
                        <div class="relative">
                            <img src="https://www.trvme.com/img/tours/austria-honeymoon-im2.jpg" alt="Europe Package" class="w-full h-48 object-cover">
                            <span class="absolute top-2 right-2 bg-blue-500 text-white text-xs px-2 py-1 rounded">Group Discount</span>
                        </div>
                        <div class="p-5">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-lg">Europe - 10D9N</h3>
                                    <p class="text-gray-600 text-sm">4-star Hotels + Breakfast</p>
                                </div>
                                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">0% Installment</span>
                            </div>
                            
                            <div class="my-4">
                                <p class="text-gray-800 font-bold">Rp 69,444/day</p>
                                <p class="text-gray-600 text-sm">Price: Rp 25,000,000</p>
                                <p class="text-gray-600 text-sm">Countdown: 360 days</p>
                            </div>
                            
                            <div class="mb-4">
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-primary h-2 rounded-full" style="width: 30%"></div>
                                </div>
                                <p class="text-xs text-gray-600 mt-1">5 people saving for this package</p>
                            </div>
                            
                            <button class="w-full bg-primary hover:bg-primary-dark text-white py-2 rounded-lg font-semibold transition cursor-pointer start-saving-btn">
                                Start Saving
                            </button>
                        </div>
                    </div>

                    <!-- Package 4 -->
                    <div class="package-item bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition" data-destination="Singapore" data-price="4500000" data-duration="3" data-popularity="10">
                        <div class="relative">
                            <img src="https://img.inews.co.id/files/inews_new/2022/09/19/tips_berlibur_ke_singapura_lebih_hemat.jpg" alt="Singapore Package" class="w-full h-48 object-cover">
                        </div>
                        <div class="p-5">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-lg">Singapore - 3D2N</h3>
                                    <p class="text-gray-600 text-sm">4-star Hotel + Breakfast</p>
                                </div>
                                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">0% Installment</span>
                            </div>
                            
                            <div class="my-4">
                                <p class="text-gray-800 font-bold">Rp 25,000/day</p>
                                <p class="text-gray-600 text-sm">Price: Rp 4,500,000</p>
                                <p class="text-gray-600 text-sm">Countdown: 180 days</p>
                            </div>
                            
                            <div class="mb-4">
                                <div class="w-full bg-gray-200 rounded-full h-2">
                                    <div class="bg-primary h-2 rounded-full" style="width: 60%"></div>
                                </div>
                                <p class="text-xs text-gray-600 mt-1">10 people saving for this package</p>
                            </div>
                            
                            <button class="w-full bg-primary hover:bg-primary-dark text-white py-2 rounded-lg font-semibold transition cursor-pointer start-saving-btn">
                                Start Saving
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Dashboard Preview -->
        <section class="py-16 bg-white">
            <div class="container mx-auto px-4">
                <h2 class="text-3xl font-bold mb-10 text-center">📊 Your Savings Dashboard</h2>
                
                <div class="max-w-2xl mx-auto bg-gradient-to-r from-primary to-secondary text-white p-8 rounded-xl shadow-lg">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="font-bold text-xl">DREAMWALLET BALANCE</h3>
                        <div class="text-2xl font-bold">Rp 8,450,000</div>
                    </div>
                    
                    <div class="bg-white bg-opacity-20 p-6 rounded-lg mb-6">
                        <h4 class="font-bold mb-4 text-white">ACTIVE SAVINGS</h4>
                        
                        <div class="space-y-4">
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span>Bali Trip</span>
                                    <span>60%</span>
                                </div>
                                <div class="w-full bg-white bg-opacity-30 rounded-full h-2">
                                    <div class="bg-white h-2 rounded-full" style="width: 60%"></div>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span>Honeymoon</span>
                                    <span>40%</span>
                                </div>
                                <div class="w-full bg-white bg-opacity-30 rounded-full h-2">
                                    <div class="bg-white h-2 rounded-full" style="width: 40%"></div>
                                </div>
                            </div>
                            
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span>Japan Fund</span>
                                    <span>10%</span>
                                </div>
                                <div class="w-full bg-white bg-opacity-30 rounded-full h-2">
                                    <div class="bg-white h-2 rounded-full" style="width: 10%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-white bg-opacity-20 p-6 rounded-lg mb-6">
                        <h4 class="font-bold mb-2">RECOMMENDATION</h4>
                        <p>"Your Bali trip can depart next month if you save an extra Rp 1.2 million this month."</p>
                    </div>
                    
                    <div class="text-center">
                        <button class="bg-white text-primary hover:bg-gray-100 px-8 py-3 rounded-lg font-semibold cursor-pointer shadow-md transition">
                            Login to View Your Dashboard
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <!-- Trust Signals -->
        <section class="py-12 bg-gray-50 mb-12 lg:mb-0">
            <div class="container mx-auto px-4">
                <div class="flex flex-wrap justify-center gap-8">
                    <div class="text-center w-[180px]">
                        <div class="text-primary mb-2">
                            <i data-feather="shield" class="w-8 h-8 mx-auto"></i>
                        </div>
                        <p class="font-semibold text-sm">Secure & Encrypted</p>
                    </div>
                    
                    <div class="text-center w-[180px]">
                        <div class="text-primary mb-2">
                            <i data-feather="award" class="w-8 h-8 mx-auto"></i>
                        </div>
                        <p class="font-semibold text-sm">OJK Registered</p>
                    </div>
                    
                    <div class="text-center w-[180px]">
                        <div class="text-primary mb-2">
                            <i data-feather="users" class="w-8 h-8 mx-auto"></i>
                        </div>
                        <p class="font-semibold text-sm">50+ Travel Partners</p>
                    </div>
                    
                    <div class="text-center w-[180px]">
                        <div class="text-primary mb-2">
                            <i data-feather="star" class="w-8 h-8 mx-auto"></i>
                        </div>
                        <p class="font-semibold text-sm">4.8/5 (10,000+ Reviews)</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    // Client-side simulation
    const saveButtons = document.querySelectorAll('.start-saving-btn');
    saveButtons.forEach(button => {
        button.addEventListener('click', () => {
            alert('Please login or sign up to start saving for this package!');
        });
    });
</script>
