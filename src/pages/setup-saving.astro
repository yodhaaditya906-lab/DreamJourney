---
import Layout from '../layouts/Layout.astro';

const { userId } = Astro.locals.auth();

if (!userId) {
    return Astro.redirect('/');
}

const title = Astro.url.searchParams.get('title') || 'Liburan Impian';
const priceStr = Astro.url.searchParams.get('price') || '0';
const dailyPriceStr = Astro.url.searchParams.get('dailyPrice') || '0';
const time = Astro.url.searchParams.get('time') || '';
const image = Astro.url.searchParams.get('image') || '';

const price = parseInt(priceStr, 10);
const dailyPrice = parseInt(dailyPriceStr, 10);
const investPrice = Math.round(price * 1.06); // 6% estimation logic
const formattedPrice = `Rp ${new Intl.NumberFormat('id-ID').format(price)}`;
const formattedInvestPrice = `Rp ${new Intl.NumberFormat('id-ID').format(investPrice)}`;

let lenteraIds: string[] = [];
try {
  const response = await fetch('https://docs.google.com/spreadsheets/d/1qie-zXXTH6xqEn_oxlZEQYCU2DDGmQn_ACWZNFI7xOM/export?format=csv');
  const csvText = await response.text();
  
  function parseCSVRow(row: string) {
      const result = [];
      let curVal = '';
      let inQuotes = false;
      for (let i = 0; i < row.length; i++) {
          if (row[i] === '"') {
              inQuotes = !inQuotes;
          } else if (row[i] === ',' && !inQuotes) {
              result.push(curVal.trim());
              curVal = '';
          } else {
              curVal += row[i];
          }
      }
      result.push(curVal.trim());
      return result;
  }

  const rows = csvText.split('\n').slice(1);
  lenteraIds = rows.filter(row => row.trim() && !row.startsWith(',')).map(row => {
      const cols = parseCSVRow(row);
      return cols[0] || "";
  }).filter(id => id !== "");
} catch (error) {
  console.error("Failed to fetch lentera data:", error);
}
---

<Layout title={`Setup Saving - ${title}`}>
    <main class="pt-24 pb-16 bg-blue-50/20 min-h-screen relative overflow-hidden">
        <!-- Elemen Latar Belakang -->
        <div class="absolute top-10 -right-10 text-blue-200/40 transform rotate-12 pointer-events-none">
            <i data-feather="briefcase" class="w-64 h-64 md:w-80 md:h-80"></i>
        </div>
        <div class="absolute bottom-10 -left-10 text-blue-200/40 transform -rotate-12 pointer-events-none">
            <i data-feather="camera" class="w-64 h-64 md:w-80 md:h-80"></i>
        </div>
        <div class="absolute top-1/2 left-10 text-blue-100/50 transform -rotate-45 pointer-events-none">
            <i data-feather="star" class="w-32 h-32 md:w-40 md:h-40"></i>
        </div>
        <div class="absolute bottom-1/4 right-20 text-blue-100/50 pointer-events-none">
            <i data-feather="heart" class="w-24 h-24 md:w-32 md:h-32"></i>
        </div>

        <div class="container mx-auto px-4 w-11/12 lg:w-3/4 max-w-5xl relative z-10">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden relative">
                <!-- Header -->
                <div class="bg-gradient-to-r from-primary to-secondary p-8 text-white text-center">
                    <h1 class="text-3xl font-bold mb-2">Setup Target Tabungan</h1>
                    <p class="opacity-90">Atur strategi tabungan untuk mewujudkan liburan impian Anda!</p>
                </div>

                <div class="p-8">
                    <!-- Summary Card -->
                    <div class="bg-blue-50 border border-blue-100 rounded-xl p-5 mb-8 flex flex-col md:flex-row items-center justify-between gap-4">
                        <div class="flex items-center gap-4 w-full md:w-auto">
                            {image && <img src={image} alt={title} class="w-20 h-20 object-cover rounded-lg shadow-sm" />}
                            <div>
                                <p class="text-sm text-blue-600 font-semibold mb-1">Destinasi Pilihan</p>
                                <h2 class="text-2xl font-bold text-gray-800" id="goal-title">{title}</h2>
                                {time && <p class="text-sm text-gray-600 mt-1"><i data-feather="calendar" class="w-3 h-3 inline"></i> {time}</p>}
                            </div>
                        </div>
                        <div class="text-left md:text-right w-full md:w-auto mt-2 md:mt-0">
                            <p class="text-sm text-blue-600 font-semibold mb-1">Target Dana</p>
                            <p class="text-xl font-bold text-gray-800" id="goal-target" data-value={price}>{formattedPrice}</p>
                        </div>
                    </div>

                    <form id="setup-form" class="space-y-8" data-daily-price={dailyPrice} data-lentera-ids={JSON.stringify(lenteraIds)}>
                        <!-- 1. Frekuensi & Nominal -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Frekuensi Menabung</label>
                                <select id="input-frequency" class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-3 outline-none focus:border-primary transition" required>
                                    <option value="Harian">Harian</option>
                                    <option value="Mingguan" selected>Mingguan</option>
                                    <option value="Bulanan">Bulanan</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Nominal Auto-Debit (Rp)</label>
                                <input type="text" id="input-amount" value="100.000" class="w-full bg-gray-200 border border-gray-300 rounded-lg px-4 py-3 outline-none cursor-not-allowed text-gray-600 font-semibold" readonly required>
                            </div>
                        </div>

                        <!-- 2. Metode Pembayaran -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-3">Metode Pembayaran</label>
                            <div class="flex space-x-4 mb-4">
                                <label class="flex-1 cursor-pointer">
                                    <input type="radio" name="payment_method" value="Cash" class="peer sr-only" required>
                                    <div class="text-center p-4 rounded-xl border-2 border-gray-200 peer-checked:border-primary peer-checked:bg-blue-50 transition font-semibold text-gray-600 peer-checked:text-primary">
                                        <i data-feather="dollar-sign" class="w-6 h-6 mx-auto mb-2"></i>
                                        Tunai (Mitra)
                                    </div>
                                </label>
                                <label class="flex-1 cursor-pointer">
                                    <input type="radio" name="payment_method" value="Cashless" class="peer sr-only" checked required>
                                    <div class="text-center p-4 rounded-xl border-2 border-gray-200 peer-checked:border-primary peer-checked:bg-blue-50 transition font-semibold text-gray-600 peer-checked:text-primary">
                                        <i data-feather="smartphone" class="w-6 h-6 mx-auto mb-2"></i>
                                        Cashless
                                    </div>
                                </label>
                            </div>

                            <!-- Dynamic Payment Detail -->
                            <div id="container-mitra" class="hidden bg-gray-50 p-4 rounded-lg border border-gray-200">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Masukkan Nomor ID Mitra Terdaftar</label>
                                <input type="text" id="input-mitra" placeholder="Contoh: MTR-00123" class="w-full bg-white border border-gray-300 rounded-lg px-4 py-2 outline-none focus:border-primary">
                            </div>
                            <div id="container-bank" class="bg-gray-50 p-4 rounded-lg border border-gray-200">
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Pilih Rekening Bank / e-Wallet</label>
                                <select id="input-bank" class="w-full bg-white border border-gray-300 rounded-lg px-4 py-2 outline-none focus:border-primary">
                                    <option value="BCA">BCA (Auto Debit)</option>
                                    <option value="Mandiri">Mandiri (Auto Debit)</option>
                                    <option value="Gopay">Gopay</option>
                                    <option value="OVO">OVO</option>
                                </select>
                            </div>
                        </div>

                        <!-- 3. Tipe Perjalanan (Solo/Group) -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-3">Tipe Perjalanan</label>
                            <div class="flex space-x-4 mb-4">
                                <label class="flex-1 cursor-pointer">
                                    <input type="radio" name="trip_type" value="Solo" class="peer sr-only" checked required>
                                    <div class="text-center p-4 rounded-xl border-2 border-gray-200 peer-checked:border-primary peer-checked:bg-blue-50 transition font-semibold text-gray-600 peer-checked:text-primary">
                                        <i data-feather="user" class="w-6 h-6 mx-auto mb-2"></i>
                                        Solo Trip
                                    </div>
                                </label>
                                <label class="flex-1 cursor-pointer">
                                    <input type="radio" name="trip_type" value="Group" class="peer sr-only" required>
                                    <div class="text-center p-4 rounded-xl border-2 border-gray-200 peer-checked:border-primary peer-checked:bg-blue-50 transition font-semibold text-gray-600 peer-checked:text-primary">
                                        <i data-feather="users" class="w-6 h-6 mx-auto mb-2"></i>
                                        Group Trip
                                    </div>
                                </label>
                            </div>

                            <!-- Dynamic Group Detail -->
                            <div id="container-group" class="hidden bg-yellow-50 p-5 rounded-xl border border-yellow-200">
                                <div class="flex justify-between items-center mb-3">
                                    <label class="block text-sm font-bold text-yellow-800"><i data-feather="users" class="w-4 h-4 inline-block mr-1"></i> Anggota Grup</label>
                                    <span class="text-xs font-bold text-yellow-800 bg-yellow-200 px-2 py-1 rounded-full" id="group-counter">0 Teman Ditambahkan</span>
                                </div>
                                
                                <div class="bg-white p-3 rounded-lg border border-yellow-300 mb-3 focus-within:ring-2 ring-yellow-400 transition">
                                    <!-- Chips Container -->
                                    <div id="friend-chips-container" class="flex flex-wrap gap-2 mb-2 empty:hidden"></div>
                                    
                                    <div class="flex gap-2">
                                        <input type="text" id="input-friend" placeholder="Ketik username / email teman disini..." class="flex-1 bg-transparent border-none outline-none text-sm px-1 placeholder-gray-400">
                                        <button type="button" id="btn-add-friend" class="bg-yellow-500 text-white px-4 py-1.5 rounded text-sm font-bold hover:bg-yellow-600 transition flex items-center">
                                            <i data-feather="plus" class="w-4 h-4 mr-1"></i> Tambah
                                        </button>
                                    </div>
                                </div>
                                
                                <p class="text-xs text-yellow-700 leading-relaxed"><i data-feather="info" class="w-3 h-3 inline-block"></i> Anda dapat menambahkan beberapa orang sekaligus. Teman Anda akan menerima notifikasi persetujuan di dashboard mereka.</p>
                            </div>
                        </div>

                        <!-- 4. Tipe Tabungan -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-3">Tipe Tabungan</label>
                            <div class="flex space-x-4">
                                <label class="flex-1 cursor-pointer">
                                    <input type="radio" name="saving_type" value="Konvensional" class="peer sr-only" checked required>
                                    <div class="text-center p-4 rounded-xl border-2 border-gray-200 peer-checked:border-primary peer-checked:bg-blue-50 transition font-semibold text-gray-600 peer-checked:text-primary flex flex-col items-center justify-center h-full">
                                        <i data-feather="box" class="w-6 h-6 mb-2"></i>
                                        <span>Konvensional</span>
                                        <span class="text-xs font-normal mt-2 opacity-80">Estimasi hasil:<br><strong class="text-sm">{formattedPrice}</strong></span>
                                    </div>
                                </label>
                                <label class="flex-1 cursor-pointer flex flex-col relative overflow-hidden group">
                                    <input type="radio" name="saving_type" value="Investasi" class="peer sr-only" required>
                                    <div class="text-center p-4 rounded-xl border-2 border-gray-200 peer-checked:border-green-500 peer-checked:bg-green-50 transition font-semibold text-gray-600 peer-checked:text-green-600 flex-1 flex flex-col items-center justify-center h-full">
                                        <i data-feather="trending-up" class="w-6 h-6 mb-2"></i>
                                        <span>Investasi Reksadana</span>
                                        <span class="text-xs font-normal mt-2 opacity-80">Estimasi hasil:<br><strong class="text-sm">{formattedInvestPrice}</strong></span>
                                    </div>
                                    <div class="absolute top-0 right-0 bg-red-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-bl-lg">PROMO</div>
                                </label>
                            </div>
                        </div>

                        <!-- 5. T&C Box -->
                        <div class="mt-8 border-t border-gray-200 pt-6">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Syarat & Ketentuan Tabungan DreamJourney</label>
                            <div class="bg-gray-50 border border-gray-200 rounded-lg h-32 overflow-y-scroll p-4 text-xs text-gray-600 mb-4 leading-relaxed">
                                <p class="mb-2"><strong>1. Ketentuan Umum:</strong> Dengan menekan tombol "Simpan", Anda menyetujui sistem akan melakukan penarikan dana secara otomatis (Auto-Debit) sesuai nominal dan frekuensi yang ditentukan.</p>
                                <p class="mb-2"><strong>2. Kebijakan Grup:</strong> Jika Anda mengundang anggota ke dalam Group Trip, dana tabungan menjadi tanggung jawab kolektif. Penarikan akan dilakukan dari akun masing-masing yang menyetujui.</p>
                                <p class="mb-2"><strong>3. Tipe Investasi:</strong> Dana yang dimasukkan dalam program "Investasi" akan dikelola oleh Manajer Investasi rekanan DreamJourney. Nilai investasi dapat berfluktuasi. DreamJourney tidak menjamin keuntungan mutlak.</p>
                                <p><strong>4. Pembatalan:</strong> Penarikan dana tabungan liburan (Withdrawal) di luar jadwal hanya dapat dilakukan dengan penalti administrasi sebesar 2%.</p>
                            </div>
                            
                            <label class="flex items-center space-x-3 cursor-pointer">
                                <input type="checkbox" id="checkbox-tnc" class="w-5 h-5 text-primary border-gray-300 rounded focus:ring-primary cursor-pointer">
                                <span class="text-sm font-semibold text-gray-800">Saya telah membaca dan menyetujui seluruh Syarat & Ketentuan di atas.</span>
                            </label>
                        </div>

                        <div class="pt-6">
                            <button type="submit" id="btn-submit" disabled class="w-full bg-gray-300 text-gray-500 py-4 rounded-xl font-bold text-lg transition shadow flex items-center justify-center">
                                Simpan Target Tabungan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('setup-form');
        const inputAmount = document.getElementById('input-amount') as HTMLInputElement;
        const inputFrequency = document.getElementById('input-frequency') as HTMLSelectElement;
        const dailyPrice = parseInt(form?.getAttribute('data-daily-price') || '0', 10);

        // Compute amount based on frequency
        function updateAmountBasedOnFrequency() {
            if (dailyPrice === 0) return;
            const freq = inputFrequency.value;
            let amount = 0;
            if (freq === 'Harian') amount = dailyPrice;
            else if (freq === 'Mingguan') amount = dailyPrice * 7;
            else if (freq === 'Bulanan') amount = dailyPrice * 30; // Approx 1 month

            inputAmount.value = new Intl.NumberFormat('id-ID').format(amount);
        }

        if (dailyPrice > 0 && inputAmount.value === '100.000') {
            updateAmountBasedOnFrequency();
        }

        inputFrequency.addEventListener('change', updateAmountBasedOnFrequency);

        // Amount formatting
        inputAmount.addEventListener('input', function() {
            let val = this.value.replace(/[^\d]/g, '');
            if (val) {
                this.value = new Intl.NumberFormat('id-ID').format(parseInt(val));
            }
        });

        // Toggle Payment Method
        const paymentRadios = document.querySelectorAll('input[name="payment_method"]');
        const containerMitra = document.getElementById('container-mitra');
        const containerBank = document.getElementById('container-bank');
        
        paymentRadios.forEach(radio => {
            radio.addEventListener('change', (e) => {
                const target = e.target as HTMLInputElement;
                if (target.value === 'Cash') {
                    containerMitra?.classList.remove('hidden');
                    containerBank?.classList.add('hidden');
                } else {
                    containerMitra?.classList.add('hidden');
                    containerBank?.classList.remove('hidden');
                }
            });
        });

        // Toggle Trip Type (Group)
        const tripRadios = document.querySelectorAll('input[name="trip_type"]');
        const containerGroup = document.getElementById('container-group');
        let groupMembers: string[] = [];
        
        tripRadios.forEach(radio => {
            radio.addEventListener('change', (e) => {
                const target = e.target as HTMLInputElement;
                if (target.value === 'Group') {
                    containerGroup?.classList.remove('hidden');
                } else {
                    containerGroup?.classList.add('hidden');
                }
            });
        });

        // Group Friend List Logic
        const btnAddFriend = document.getElementById('btn-add-friend');
        const inputFriend = document.getElementById('input-friend') as HTMLInputElement;
        const friendListEl = document.getElementById('friend-chips-container');

        function renderFriends() {
            if (!friendListEl) return;
            friendListEl.innerHTML = '';
            groupMembers.forEach((friend, idx) => {
                const chip = document.createElement('div');
                chip.className = 'flex items-center bg-yellow-100 text-yellow-800 text-sm px-3 py-1.5 rounded-full border border-yellow-200 shadow-sm';
                chip.innerHTML = `
                    <span class="font-medium mr-2">${friend}</span>
                    <button type="button" class="text-yellow-600 hover:text-red-500 transition btn-remove-friend" data-idx="${idx}">
                        <i data-feather="x" class="w-3 h-3"></i>
                    </button>
                `;
                friendListEl.appendChild(chip);
            });

            // Re-initialize feather icons for the new 'x' icons
            if ((window as any).feather) {
                (window as any).feather.replace();
            }

            // Attach remove logic
            const removeBtns = document.querySelectorAll('.btn-remove-friend');
            removeBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const idxStr = (e.currentTarget as HTMLElement).getAttribute('data-idx');
                    if (idxStr !== null) {
                        groupMembers.splice(parseInt(idxStr, 10), 1);
                        renderFriends();
                    }
                });
            });

            const counter = document.getElementById('group-counter');
            if (counter) {
                counter.innerText = `${groupMembers.length} Teman Ditambahkan`;
            }
        }

        btnAddFriend?.addEventListener('click', () => {
            const val = inputFriend.value.trim();
            if (val && !groupMembers.includes(val)) {
                groupMembers.push(val);
                inputFriend.value = '';
                renderFriends();
                inputFriend.focus();
            }
        });

        // Allow pressing Enter to add friend (without submitting form)
        inputFriend.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                btnAddFriend?.click();
            }
        });

        // T&C Logic
        const checkboxTnc = document.getElementById('checkbox-tnc') as HTMLInputElement;
        const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

        checkboxTnc.addEventListener('change', () => {
            if (checkboxTnc.checked) {
                btnSubmit.disabled = false;
                btnSubmit.classList.remove('bg-gray-300', 'text-gray-500');
                btnSubmit.classList.add('bg-primary', 'text-white', 'hover:bg-blue-700', 'cursor-pointer');
            } else {
                btnSubmit.disabled = true;
                btnSubmit.classList.add('bg-gray-300', 'text-gray-500');
                btnSubmit.classList.remove('bg-primary', 'text-white', 'hover:bg-blue-700', 'cursor-pointer');
            }
        });

        // Form Submit
        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!checkboxTnc.checked) return;

            const title = document.getElementById('goal-title')?.innerText || '';
            const targetEl = document.getElementById('goal-target');
            const targetAmount = parseInt(targetEl?.getAttribute('data-value') || '0');
            
            const frequency = (document.getElementById('input-frequency') as HTMLSelectElement).value;
            const amountRaw = inputAmount.value.replace(/[^\d]/g, '');
            const autoDebitAmount = parseInt(amountRaw || '0');

            const paymentMethod = (document.querySelector('input[name="payment_method"]:checked') as HTMLInputElement).value;
            let paymentDetail = '';
            
            const lenteraIds = JSON.parse(form?.getAttribute('data-lentera-ids') || '[]');

            if (paymentMethod === 'Cash') {
                const mitraInput = (document.getElementById('input-mitra') as HTMLInputElement).value.trim();
                if (!mitraInput) {
                    alert('Nomor ID Mitra Terdaftar wajib diisi jika Anda memilih metode Tunai (Mitra).');
                    (document.getElementById('input-mitra') as HTMLInputElement).focus();
                    return;
                }
                if (!lenteraIds.includes(mitraInput)) {
                    alert('ID Mitra yang Anda masukkan (' + mitraInput + ') tidak terdaftar di sistem. Silakan periksa kembali.');
                    (document.getElementById('input-mitra') as HTMLInputElement).focus();
                    return;
                }
                paymentDetail = mitraInput;
            } else {
                paymentDetail = (document.getElementById('input-bank') as HTMLSelectElement).value;
            }

            const tripType = (document.querySelector('input[name="trip_type"]:checked') as HTMLInputElement).value;
            const savingType = (document.querySelector('input[name="saving_type"]:checked') as HTMLInputElement).value;

            if (tripType === 'Group' && groupMembers.length === 0) {
                alert('Silakan tambahkan minimal 1 anggota grup untuk Group Trip.');
                const inputFriend = document.getElementById('input-friend');
                if (inputFriend) inputFriend.focus();
                return;
            }

            // Snapshot breakdown to database
            const params = new URLSearchParams(window.location.search);
            let pAkomodasi = parseInt(params.get('akomodasi') || 'NaN');
            let pTransport = parseInt(params.get('transport') || 'NaN');
            let pWahana = parseInt(params.get('wahana') || 'NaN');
            let pLainnya = parseInt(params.get('lainnya') || 'NaN');

            if (isNaN(pAkomodasi) && isNaN(pWahana)) {
                pAkomodasi = Math.round(targetAmount * 0.45);
                pTransport = 0;
                pWahana = Math.round(targetAmount * 0.30);
                pLainnya = Math.round(targetAmount * 0.25);
            } else {
                pAkomodasi = pAkomodasi || 0;
                pTransport = pTransport || 0;
                pWahana = pWahana || 0;
                pLainnya = pLainnya || 0;
            }

            const breakdown = {
                accommodations: pAkomodasi > 0 ? [{ name: "Akomodasi Penginapan", price: pAkomodasi }] : [],
                transports: pTransport > 0 ? [{ name: "Transportasi", price: pTransport }] : [],
                activities: pWahana > 0 ? [{ name: "Tiket Masuk Wahana", price: pWahana }] : [],
                others: pLainnya > 0 ? [{ name: "Konsumsi, Asuransi & Lain-lain", price: pLainnya }] : [],
                buffer: 0
            };
            paymentDetail = paymentDetail + '|||' + JSON.stringify(breakdown);

            btnSubmit.innerHTML = '<i data-feather="loader" class="w-5 h-5 animate-spin mr-2"></i> Memproses...';
            btnSubmit.disabled = true;

            const payload = {
                action: 'ADD_GOAL_FULL',
                title,
                targetAmount,
                frequency,
                autoDebitAmount,
                paymentMethod,
                paymentDetail,
                tripType,
                groupMembers,
                savingType
            };

            try {
                const res = await fetch('/api/wallet', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (res.ok) {
                    window.location.href = '/dashboard';
                } else {
                    alert('Terjadi kesalahan saat menyimpan pengaturan.');
                    window.location.reload();
                }
            } catch (err) {
                console.error(err);
                alert('Gangguan koneksi.');
            }
        });
    });
</script>
