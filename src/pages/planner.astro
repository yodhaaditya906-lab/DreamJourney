---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Trip Planner - DreamJourney">
    <main class="pt-20">
        <!-- Trip Planner -->
        <section id="planner" class="py-16 bg-gray-50">
            <div class="container mx-auto px-4">
                <h2 class="text-3xl font-bold mb-10 text-center">🎨 Design Your Dream Vacation</h2>
                
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
                    <!-- Steps -->
                    <div class="space-y-8">
                        <div class="flex items-start">
                            <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0 font-bold">1</div>
                            <div>
                                <h3 class="font-bold text-xl mb-2">Choose Destination</h3>
                                <p class="text-gray-600">Select from our worldwide destinations or create a multi-city itinerary</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start">
                            <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0 font-bold">2</div>
                            <div>
                                <h3 class="font-bold text-xl mb-2">Set Budget</h3>
                                <p class="text-gray-600">Adjust your budget allocation for flights, hotels, activities and dining</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start">
                            <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0 font-bold">3</div>
                            <div>
                                <h3 class="font-bold text-xl mb-2">Select Dates</h3>
                                <p class="text-gray-600">Pick your travel dates with seasonal price recommendations</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start">
                            <div class="bg-primary text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0 font-bold">4</div>
                            <div>
                                <h3 class="font-bold text-xl mb-2">Payment Options</h3>
                                <p class="text-gray-600">Choose to pay upfront, in installments, or start a savings plan</p>
                            </div>
                        </div>
                        
                        <a href="/design-trip" class="mt-6 inline-block bg-secondary hover:bg-secondary-dark text-white px-8 py-3 rounded-lg font-semibold text-center transition shadow-md">
                            Start Designing Your Trip
                        </a>
                    </div>
                    
                    <!-- Preview -->
                    <div class="bg-white p-6 rounded-xl shadow-lg">
                        <div class="relative h-64 mb-4 rounded-lg overflow-hidden">
                            <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?q=80&w=2070&auto=format&fit=crop" alt="Trip Preview" class="w-full h-full object-cover">
                            <div class="absolute inset-0 bg-gradient-to-t from-black to-transparent opacity-70"></div>
                            <div class="absolute bottom-4 left-4 text-white">
                                <h3 class="font-bold text-xl">Family Trip to Italy</h3>
                                <p>Rome, Florence, Venice - 10 Days</p>
                            </div>
                        </div>
                        
                        <div class="grid grid-cols-3 gap-4 mb-6">
                            <div class="text-center">
                                <div class="text-primary font-bold text-lg md:text-xl">Rp 45,000,000</div>
                                <div class="text-gray-600 text-xs md:text-sm">Total Budget</div>
                            </div>
                            <div class="text-center">
                                <div class="text-secondary font-bold text-lg md:text-xl">June 2024</div>
                                <div class="text-gray-600 text-xs md:text-sm">Travel Date</div>
                            </div>
                            <div class="text-center">
                                <div class="text-accent font-bold text-lg md:text-xl">4 People</div>
                                <div class="text-gray-600 text-xs md:text-sm">Travelers</div>
                            </div>
                        </div>
                        
                        <div class="mb-6">
                            <h4 class="font-bold mb-2">Budget Breakdown</h4>
                            <div class="space-y-2">
                                <div class="flex justify-between text-sm">
                                    <span>Flights</span>
                                    <span class="font-semibold">Rp 18,000,000</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span>Hotels</span>
                                    <span class="font-semibold">Rp 15,000,000</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span>Activities</span>
                                    <span class="font-semibold">Rp 7,000,000</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span>Dining</span>
                                    <span class="font-semibold">Rp 5,000,000</span>
                                </div>
                            </div>
                        </div>
                        
                        <div>
                            <h4 class="font-bold mb-2">Payment Options</h4>
                            <div class="space-y-3 text-sm">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="payment" class="w-4 h-4 text-primary" checked>
                                    <span>Full Payment (Rp 45,000,000)</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="payment" class="w-4 h-4 text-primary">
                                    <span>Installment (Rp 1,416,667/month for 6 months)</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="payment" class="w-4 h-4 text-primary">
                                    <span>Savings Plan (Save Rp 1,875,000/month for 24 months)</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
