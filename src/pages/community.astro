---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Community - DreamJourney">
    <main class="pt-20">
        <!-- Community Section -->
        <section id="community" class="py-16 bg-gray-50">
            <div class="container mx-auto px-4">
                <h2 class="text-3xl font-bold mb-10 text-center">👥 Menabung Bersama Komunitas</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
                    <!-- Member 1 -->
                    <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col justify-between transform hover:-translate-y-1">
                        <div>
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center">
                                    <div class="relative">
                                        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1887&auto=format&fit=crop" alt="Andi" class="w-14 h-14 rounded-full mr-4 object-cover border-2 border-primary p-0.5">
                                        <span class="absolute bottom-0 right-3 bg-green-500 w-4 h-4 border-2 border-white rounded-full"></span>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800 text-lg">Andi</h3>
                                        <p class="text-gray-500 text-xs">Karyawan Swasta</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-5">
                                <span class="bg-blue-50 text-blue-700 text-xs font-bold px-3 py-1.5 rounded-full inline-block mb-3 border border-blue-100">
                                    ✈️ Berhasil Liburan ke Jepang
                                </span>
                                <div class="relative">
                                    <i data-feather="message-circle" class="absolute -top-1 -left-2 w-8 h-8 text-gray-100 opacity-50"></i>
                                    <p class="text-gray-700 text-sm leading-relaxed relative z-10 pl-2 border-l-2 border-primary">
                                        "Terima kasih DreamJourney! Auto-debit harian sangat membantu karena saya termasuk orang yang boros. Akhirnya bisa menikmati Sakura secara langsung tanpa pusing tagihan setelah pulang liburan."
                                    </p>
                                </div>
                            </div>
                        </div>
                        
                        <button class="w-full bg-gray-50 hover:bg-red-50 text-gray-600 hover:text-red-500 border border-gray-200 hover:border-red-200 py-2.5 rounded-xl font-semibold text-sm transition-all cursor-pointer cheer-btn flex items-center justify-center group" data-cheers="128">
                            <i data-feather="heart" class="w-4 h-4 mr-2 group-hover:fill-red-500 transition-colors"></i> Beri Apresiasi (128)
                        </button>
                    </div>
                    
                    <!-- Member 2 -->
                    <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col justify-between transform hover:-translate-y-1">
                        <div>
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center">
                                    <div class="relative">
                                        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=1887&auto=format&fit=crop" alt="Sarah" class="w-14 h-14 rounded-full mr-4 object-cover border-2 border-primary p-0.5">
                                        <span class="absolute bottom-0 right-3 bg-green-500 w-4 h-4 border-2 border-white rounded-full"></span>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800 text-lg">Sarah & Suami</h3>
                                        <p class="text-gray-500 text-xs">Wirausaha</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-5">
                                <span class="bg-blue-50 text-blue-700 text-xs font-bold px-3 py-1.5 rounded-full inline-block mb-3 border border-blue-100">
                                    🏰 Berhasil Keliling Eropa
                                </span>
                                <div class="relative">
                                    <i data-feather="message-circle" class="absolute -top-1 -left-2 w-8 h-8 text-gray-100 opacity-50"></i>
                                    <p class="text-gray-700 text-sm leading-relaxed relative z-10 pl-2 border-l-2 border-primary">
                                        "Fitur Group Trip benar-benar penyelamat! Saya dan suami bisa menabung di akun masing-masing untuk satu target bersama. Perjalanan merayakan <i>anniversary</i> kelima ke Eropa akhirnya terwujud dengan mulus."
                                    </p>
                                </div>
                            </div>
                        </div>
                        
                        <button class="w-full bg-gray-50 hover:bg-red-50 text-gray-600 hover:text-red-500 border border-gray-200 hover:border-red-200 py-2.5 rounded-xl font-semibold text-sm transition-all cursor-pointer cheer-btn flex items-center justify-center group" data-cheers="342">
                            <i data-feather="heart" class="w-4 h-4 mr-2 group-hover:fill-red-500 transition-colors"></i> Beri Apresiasi (342)
                        </button>
                    </div>
                    
                    <!-- Member 3 -->
                    <div class="bg-white p-6 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col justify-between transform hover:-translate-y-1">
                        <div>
                            <div class="flex items-center justify-between mb-4">
                                <div class="flex items-center">
                                    <div class="relative">
                                        <img src="https://images.unsplash.com/photo-1552058544-f2b08422138a?q=80&w=1899&auto=format&fit=crop" alt="Budi" class="w-14 h-14 rounded-full mr-4 object-cover border-2 border-primary p-0.5">
                                        <span class="absolute bottom-0 right-3 bg-green-500 w-4 h-4 border-2 border-white rounded-full"></span>
                                    </div>
                                    <div>
                                        <h3 class="font-bold text-gray-800 text-lg">Budi</h3>
                                        <p class="text-gray-500 text-xs">Mahasiswa</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mb-5">
                                <span class="bg-blue-50 text-blue-700 text-xs font-bold px-3 py-1.5 rounded-full inline-block mb-3 border border-blue-100">
                                    🏖️ Healing Solo ke Bali
                                </span>
                                <div class="relative">
                                    <i data-feather="message-circle" class="absolute -top-1 -left-2 w-8 h-8 text-gray-100 opacity-50"></i>
                                    <p class="text-gray-700 text-sm leading-relaxed relative z-10 pl-2 border-l-2 border-primary">
                                        "Sebagai mahasiswa, uang jajan tentu terbatas. Tapi dengan memotong pengeluaran kopi dan memilih skema nabung harian, tahu-tahu tabungan sudah cukup buat <i>healing</i> sendirian ke Bali. Recommended banget!"
                                    </p>
                                </div>
                            </div>
                        </div>
                        
                        <button class="w-full bg-gray-50 hover:bg-red-50 text-gray-600 hover:text-red-500 border border-gray-200 hover:border-red-200 py-2.5 rounded-xl font-semibold text-sm transition-all cursor-pointer cheer-btn flex items-center justify-center group" data-cheers="89">
                            <i data-feather="heart" class="w-4 h-4 mr-2 group-hover:fill-red-500 transition-colors"></i> Beri Apresiasi (89)
                        </button>
                    </div>
                </div>
                
                <div class="mt-10 text-center">
                    <button id="btn-join-community" class="bg-white border border-primary text-primary hover:bg-primary hover:text-white px-8 py-3 rounded-lg font-bold shadow-md transition cursor-pointer">
                        Bergabung dengan Komunitas
                    </button>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cheerButtons = document.querySelectorAll('.cheer-btn');
        cheerButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                let count = parseInt(btn.getAttribute('data-cheers') || "0");
                count += 1;
                btn.setAttribute('data-cheers', count.toString());
                btn.textContent = `Beri Semangat! (${count} dukungan)`;
                
                // Add minor micro-interaction feedback
                btn.classList.add('bg-blue-50', 'text-primary', 'scale-[1.03]');
                setTimeout(() => {
                    btn.classList.remove('scale-[1.03]');
                }, 100);
            });
        });

        const joinBtn = document.getElementById('btn-join-community');
        if (joinBtn) {
            joinBtn.addEventListener('click', () => {
                alert('Permintaan bergabung diterima! Silakan daftar atau masuk untuk bergabung dengan lingkaran komunitas kami.');
            });
        }
    });
</script>
