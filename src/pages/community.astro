---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Community - DreamJourney">
    <main class="pt-20">
        <!-- Community Section -->
        <section id="community" class="py-16 bg-gray-50">
            <div class="container mx-auto px-4">
                <h2 class="text-3xl font-bold mb-10 text-center">👥 Community Saving Together</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
                    <!-- Member 1 -->
                    <div class="bg-white p-6 rounded-xl shadow hover:shadow-md transition border border-gray-100 flex flex-col justify-between">
                        <div>
                            <div class="flex items-center mb-4">
                                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1887&auto=format&fit=crop" alt="User" class="w-12 h-12 rounded-full mr-4 object-cover border border-gray-200">
                                <div>
                                    <h3 class="font-bold text-gray-800">Andi (28)</h3>
                                    <p class="text-gray-500 text-sm">Jakarta</p>
                                </div>
                            </div>
                            
                            <div class="mb-4 text-sm text-gray-700 space-y-1">
                                <p class="text-gray-900 font-medium">🎯 Target: Japan Cherry Blossom 2024</p>
                                <p class="text-gray-600">💰 Need: Rp 25,000,000</p>
                                <p class="text-gray-600">📅 Deadline: 8 months left</p>
                            </div>
                            
                            <div class="mb-4">
                                <div class="w-full bg-gray-250 rounded-full h-2">
                                    <div class="bg-primary h-2 rounded-full" style="width: 75%"></div>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">75% complete</p>
                            </div>
                            
                            <p class="text-gray-600 italic text-sm mb-6">"3 months to go! Can't wait to see the sakura!"</p>
                        </div>
                        
                        <button class="w-full bg-gray-100 hover:bg-gray-200 text-gray-800 py-2 rounded-lg font-semibold text-sm transition cursor-pointer cheer-btn" data-cheers="24">
                            Cheer! (24 cheers)
                        </button>
                    </div>
                    
                    <!-- Member 2 -->
                    <div class="bg-white p-6 rounded-xl shadow hover:shadow-md transition border border-gray-100 flex flex-col justify-between">
                        <div>
                            <div class="flex items-center mb-4">
                                <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=1887&auto=format&fit=crop" alt="User" class="w-12 h-12 rounded-full mr-4 object-cover border border-gray-200">
                                <div>
                                    <h3 class="font-bold text-gray-800">Sarah (32)</h3>
                                    <p class="text-gray-500 text-sm">Bandung</p>
                                </div>
                            </div>
                            
                            <div class="mb-4 text-sm text-gray-700 space-y-1">
                                <p class="text-gray-900 font-medium">🎯 Target: Europe Summer 2024</p>
                                <p class="text-gray-600">💰 Need: Rp 40,000,000</p>
                                <p class="text-gray-600">📅 Deadline: 12 months left</p>
                            </div>
                            
                            <div class="mb-4">
                                <div class="w-full bg-gray-250 rounded-full h-2">
                                    <div class="bg-primary h-2 rounded-full" style="width: 30%"></div>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">30% complete</p>
                            </div>
                            
                            <p class="text-gray-600 italic text-sm mb-6">"Saving with my husband for our 5th anniversary trip!"</p>
                        </div>
                        
                        <button class="w-full bg-gray-100 hover:bg-gray-200 text-gray-800 py-2 rounded-lg font-semibold text-sm transition cursor-pointer cheer-btn" data-cheers="42">
                            Cheer! (42 cheers)
                        </button>
                    </div>
                    
                    <!-- Member 3 -->
                    <div class="bg-white p-6 rounded-xl shadow hover:shadow-md transition border border-gray-100 flex flex-col justify-between">
                        <div>
                            <div class="flex items-center mb-4">
                                <img src="https://images.unsplash.com/photo-1552058544-f2b08422138a?q=80&w=1899&auto=format&fit=crop" alt="User" class="w-12 h-12 rounded-full mr-4 object-cover border border-gray-200">
                                <div>
                                    <h3 class="font-bold text-gray-800">Budi (25)</h3>
                                    <p class="text-gray-500 text-sm">Surabaya</p>
                                </div>
                            </div>
                            
                            <div class="mb-4 text-sm text-gray-700 space-y-1">
                                <p class="text-gray-900 font-medium">🎯 Target: Bali Solo Trip</p>
                                <p class="text-gray-600">💰 Need: Rp 5,000,000</p>
                                <p class="text-gray-600">📅 Deadline: 2 months left</p>
                            </div>
                            
                            <div class="mb-4">
                                <div class="w-full bg-gray-250 rounded-full h-2">
                                    <div class="bg-primary h-2 rounded-full" style="width: 90%"></div>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">90% complete</p>
                            </div>
                            
                            <p class="text-gray-600 italic text-sm mb-6">"Almost there! First solo trip ever!"</p>
                        </div>
                        
                        <button class="w-full bg-gray-100 hover:bg-gray-200 text-gray-800 py-2 rounded-lg font-semibold text-sm transition cursor-pointer cheer-btn" data-cheers="15">
                            Cheer! (15 cheers)
                        </button>
                    </div>
                </div>
                
                <div class="mt-10 text-center">
                    <button id="btn-join-community" class="bg-white border border-primary text-primary hover:bg-primary hover:text-white px-8 py-3 rounded-lg font-bold shadow-md transition cursor-pointer">
                        Join the Community
                    </button>
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const cheerButtons = document.querySelectorAll('.cheer-btn');
        cheerButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                let count = parseInt(btn.getAttribute('data-cheers') || "0");
                count += 1;
                btn.setAttribute('data-cheers', count.toString());
                btn.textContent = `Cheer! (${count} cheers)`;
                
                // Add minor micro-interaction feedback
                btn.classList.add('bg-blue-50', 'text-primary', 'scale-[1.03]');
                setTimeout(() => {
                    btn.classList.remove('scale-[1.03]');
                }, 100);
            });
        });

        const joinBtn = document.getElementById('btn-join-community');
        if (joinBtn) {
            joinBtn.addEventListener('click', () => {
                alert('Join request received! Register or login to join our saving circles community.');
            });
        }
    });
</script>
