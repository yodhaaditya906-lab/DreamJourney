---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

const { userId } = Astro.locals.auth();
if (!userId) {
    return Astro.redirect('/');
}

const { id } = Astro.params;

const { data: goal } = await supabase.from('goals').select('*').eq('id', id).single();

if (!goal || goal.user_id !== userId) {
    return Astro.redirect('/dashboard');
}

// Simulasi H-14
// Dalam implementasi nyata, ini akan dicek berdasarkan goal.target_date
const isH14 = true; 

// Asumsi besaran potongan jika H-14 (dalam persen)
const hotelPenaltyRate = 0.30; // 30%
const transportPenaltyRate = 0.20; // 20%
const attractionPenaltyRate = 0.15; // 15%
const totalPenaltyRate = hotelPenaltyRate + transportPenaltyRate + attractionPenaltyRate; // 65%

const savedAmount = goal.saved_amount || 0;

// Kalkulasi nominal potongan
const hotelPenalty = Math.floor(savedAmount * hotelPenaltyRate);
const transportPenalty = Math.floor(savedAmount * transportPenaltyRate);
const attractionPenalty = Math.floor(savedAmount * attractionPenaltyRate);
const penaltyAmount = hotelPenalty + transportPenalty + attractionPenalty;

const refundAmount = Math.max(0, savedAmount - penaltyAmount);

const formatRp = (num: number) => `Rp ${num.toLocaleString('id-ID')}`;
---

<Layout title={`Batal Perjalanan - ${goal.title}`}>
    <main class="pt-24 pb-16 bg-gray-50 min-h-screen">
        <div class="container mx-auto px-4 max-w-3xl">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                <div class="bg-gradient-to-r from-red-500 to-red-600 p-8 text-white text-center">
                    <h1 class="text-3xl font-bold mb-2 flex justify-center items-center">
                        <i data-feather="alert-triangle" class="mr-3 w-8 h-8"></i> Konfirmasi Pembatalan
                    </h1>
                    <p class="opacity-90">Anda akan membatalkan target perjalanan: <strong>{goal.title}</strong></p>
                </div>

                <div class="p-8">
                    <!-- Ringkasan Tabungan -->
                    <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-8 flex justify-between items-center">
                        <div>
                            <p class="text-sm text-gray-500 font-semibold mb-1">Total Tabungan Terkumpul</p>
                            <p class="text-2xl font-bold text-gray-800">{formatRp(savedAmount)}</p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm text-gray-500 font-semibold mb-1">Target Penuh</p>
                            <p class="text-lg font-bold text-gray-600">{formatRp(goal.target_amount)}</p>
                        </div>
                    </div>

                    {/* Warning H-14 */}
                    {isH14 && savedAmount > 0 && (
                        <div class="bg-orange-50 border border-orange-200 rounded-xl p-6 mb-8 relative overflow-hidden">
                            <div class="absolute top-0 right-0 w-16 h-16 bg-orange-100 rounded-bl-full flex items-start justify-end p-3 text-orange-500">
                                <i data-feather="info" class="w-6 h-6"></i>
                            </div>
                            <h3 class="text-lg font-bold text-orange-800 mb-3">Pemberitahuan Pembatalan Mendekati Hari H</h3>
                            <p class="text-sm text-orange-700 mb-4 leading-relaxed">
                                Karena Anda melakukan pembatalan pada waktu <strong>H-14 (atau kurang)</strong> dari jadwal keberangkatan, dana tabungan Anda tidak dapat dikembalikan 100% karena adanya biaya penalti dari pihak-pihak terkait.
                            </p>
                            
                            <div class="bg-white rounded-lg p-4 border border-orange-100 space-y-2 mb-4">
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-600">Penalti Hotel (30%)</span>
                                    <span class="font-bold text-red-500">- {formatRp(hotelPenalty)}</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="text-gray-600">Penalti Transportasi (20%)</span>
                                    <span class="font-bold text-red-500">- {formatRp(transportPenalty)}</span>
                                </div>
                                <div class="flex justify-between text-sm pb-2 border-b border-gray-100">
                                    <span class="text-gray-600">Penalti Wahana/Destinasi (15%)</span>
                                    <span class="font-bold text-red-500">- {formatRp(attractionPenalty)}</span>
                                </div>
                                <div class="flex justify-between text-sm pt-2 font-bold">
                                    <span class="text-gray-800">Estimasi Dana Dikembalikan</span>
                                    <span class="text-green-600">{formatRp(refundAmount)}</span>
                                </div>
                            </div>
                        </div>
                    )}

                    <form id="cancel-form" class="space-y-8" data-goal-id={goal.id} data-refund-amount={refundAmount} data-penalty-amount={penaltyAmount}>
                        
                        <!-- Alasan Pembatalan -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-3">Mengapa Anda ingin membatalkan perjalanan ini?</label>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                <label class="cursor-pointer">
                                    <input type="radio" name="cancel_reason" value="Kendala Keuangan" class="peer sr-only" required>
                                    <div class="p-3 rounded-lg border border-gray-200 peer-checked:border-red-500 peer-checked:bg-red-50 transition text-sm font-medium text-gray-700 peer-checked:text-red-700">
                                        Kendala Keuangan
                                    </div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="cancel_reason" value="Ingin Ganti Destinasi" class="peer sr-only" required>
                                    <div class="p-3 rounded-lg border border-gray-200 peer-checked:border-red-500 peer-checked:bg-red-50 transition text-sm font-medium text-gray-700 peer-checked:text-red-700">
                                        Ingin Ganti Destinasi
                                    </div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="cancel_reason" value="Urusan Mendadak" class="peer sr-only" required>
                                    <div class="p-3 rounded-lg border border-gray-200 peer-checked:border-red-500 peer-checked:bg-red-50 transition text-sm font-medium text-gray-700 peer-checked:text-red-700">
                                        Urusan Mendadak / Jadwal Bentrok
                                    </div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="cancel_reason" value="Lainnya" class="peer sr-only" required>
                                    <div class="p-3 rounded-lg border border-gray-200 peer-checked:border-red-500 peer-checked:bg-red-50 transition text-sm font-medium text-gray-700 peer-checked:text-red-700">
                                        Lainnya
                                    </div>
                                </label>
                            </div>
                        </div>

                        <!-- Keluhan / Masalah -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Ceritakan Keluhan / Masalah Anda (Opsional)</label>
                            <textarea id="cancel-complaint" rows="4" class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-3 outline-none focus:border-red-500 transition text-sm" placeholder="Apakah ada pelayanan atau kendala teknis yang membuat Anda membatalkan?"></textarea>
                        </div>

                        <!-- T&C Box -->
                        <div class="border-t border-gray-200 pt-6">
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Ketentuan Pembatalan & Pengembalian Dana</label>
                            <div class="bg-gray-50 border border-gray-200 rounded-lg h-32 overflow-y-scroll p-4 text-xs text-gray-600 mb-4 leading-relaxed">
                                <p class="mb-2"><strong>1. Proses Refund:</strong> Dana yang dapat dikembalikan akan langsung masuk ke saldo dompet (Balance) akun DreamJourney Anda dalam waktu 1x24 jam.</p>
                                <p class="mb-2"><strong>2. Penalti Pembatalan H-14:</strong> Pembatalan yang dilakukan dalam kurun waktu 14 hari sebelum target tanggal keberangkatan akan dikenakan biaya penalti karena sistem telah membayarkan DP ke mitra Hotel, Transportasi, dan Destinasi terkait. Persentase penalti bervariasi tergantung kesepakatan mitra.</p>
                                <p class="mb-2"><strong>3. Finalitas:</strong> Tindakan pembatalan ini bersifat permanen. Data target perjalanan dan riwayat auto-debit untuk target ini akan dihapus/dihentikan. Anda harus membuat target baru jika ingin menabung kembali.</p>
                                <p><strong>4. Layanan Pelanggan:</strong> Jika Anda memiliki pertanyaan lebih lanjut, silakan hubungi tim Support melalui aplikasi.</p>
                            </div>
                            
                            <label class="flex items-start space-x-3 cursor-pointer">
                                <input type="checkbox" id="checkbox-tnc-cancel" class="mt-1 w-5 h-5 text-red-600 border-gray-300 rounded focus:ring-red-500 cursor-pointer">
                                <span class="text-sm font-semibold text-gray-800">Saya telah membaca dan menyetujui Ketentuan Pembatalan, dan bersedia menerima dana pengembalian sesuai estimasi perhitungan sistem.</span>
                            </label>
                        </div>

                        <div class="pt-6 flex gap-4">
                            <a href="/dashboard" class="w-1/3 bg-gray-200 text-gray-700 py-4 rounded-xl font-bold text-center hover:bg-gray-300 transition">
                                Kembali
                            </a>
                            <button type="submit" id="btn-submit-cancel" disabled class="w-2/3 bg-gray-300 text-gray-500 py-4 rounded-xl font-bold text-lg transition shadow flex items-center justify-center">
                                Konfirmasi Batal
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('cancel-form');
        const checkboxTnc = document.getElementById('checkbox-tnc-cancel') as HTMLInputElement;
        const btnSubmit = document.getElementById('btn-submit-cancel') as HTMLButtonElement;

        if (checkboxTnc && btnSubmit) {
            checkboxTnc.addEventListener('change', () => {
                if (checkboxTnc.checked) {
                    btnSubmit.disabled = false;
                    btnSubmit.classList.remove('bg-gray-300', 'text-gray-500');
                    btnSubmit.classList.add('bg-red-600', 'text-white', 'hover:bg-red-700', 'cursor-pointer');
                } else {
                    btnSubmit.disabled = true;
                    btnSubmit.classList.add('bg-gray-300', 'text-gray-500');
                    btnSubmit.classList.remove('bg-red-600', 'text-white', 'hover:bg-red-700', 'cursor-pointer');
                }
            });
        }

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!checkboxTnc.checked) return;

            const goalId = form.getAttribute('data-goal-id');
            const refundAmount = parseInt(form.getAttribute('data-refund-amount') || '0', 10);
            const penaltyAmount = parseInt(form.getAttribute('data-penalty-amount') || '0', 10);
            
            const reasonEl = document.querySelector('input[name="cancel_reason"]:checked') as HTMLInputElement;
            const reason = reasonEl ? reasonEl.value : 'Lainnya';
            const complaint = (document.getElementById('cancel-complaint') as HTMLTextAreaElement).value;

            btnSubmit.innerHTML = '<i data-feather="loader" class="w-5 h-5 animate-spin mr-2"></i> Memproses...';
            btnSubmit.disabled = true;

            try {
                const res = await fetch('/api/wallet', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        action: 'CANCEL_GOAL',
                        goalId,
                        refundAmount,
                        penaltyAmount,
                        reason,
                        complaint
                    })
                });

                if (res.ok) {
                    // Redirect back to dashboard
                    window.location.href = '/dashboard';
                } else {
                    alert('Terjadi kesalahan saat memproses pembatalan.');
                    window.location.reload();
                }
            } catch (err) {
                console.error(err);
                alert('Gangguan koneksi.');
            }
        });
    });
</script>
