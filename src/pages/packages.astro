---
import Layout from '../layouts/Layout.astro';

let packages = [];
try {
  const response = await fetch('https://docs.google.com/spreadsheets/d/16Dv2yv08HNUUsbnmH-9qUCiW2gth5DWYNYAqmMiMZ4g/export?format=csv');
  const csvText = await response.text();
  
  const imageMap = {
    "bali": "https://images.unsplash.com/photo-1537996194471-e657df975ab4?q=80&w=600&auto=format&fit=crop",
    "jogja": "https://images.unsplash.com/photo-1626125345510-4603468eedfb?q=80&w=600&auto=format&fit=crop",
    "malioboro": "https://images.unsplash.com/photo-1626125345510-4603468eedfb?q=80&w=600&auto=format&fit=crop",
    "bandung": "https://images.unsplash.com/photo-1590559899147-eb54a69622df?q=80&w=600&auto=format&fit=crop",
    "puncak bogor": "https://images.unsplash.com/photo-1626082928503-4c91b5c4644d?q=80&w=600&auto=format&fit=crop",
    "malang": "https://images.unsplash.com/photo-1602167732001-97b7b137a1f5?q=80&w=600&auto=format&fit=crop",
    "gunung bromo": "https://images.unsplash.com/photo-1602167732001-97b7b137a1f5?q=80&w=600&auto=format&fit=crop",
    "surabaya": "https://images.unsplash.com/photo-1601999109332-542b18dbec57?q=80&w=600&auto=format&fit=crop",
    "pulau karimun jawa": "https://images.unsplash.com/photo-1516690561799-46d8f74f9abf?q=80&w=600&auto=format&fit=crop",
    "banda neira": "https://images.unsplash.com/photo-1516483638261-f4dbaf036963?q=80&w=600&auto=format&fit=crop",
    "raja ampat": "https://images.unsplash.com/photo-1544551763-46a013bb70d5?q=80&w=600&auto=format&fit=crop"
  };

  const defaultImage = "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=600&auto=format&fit=crop";

  const rows = csvText.split('\n').slice(1);
  packages = rows.filter(row => row.trim() && !row.startsWith(',')).map((row, index) => {
    const cols = row.split(',');
    const title = cols[0] ? cols[0].trim() : "Unknown";
    const desc = cols[1] ? cols[1].trim() : "";
    const dailyPrice = cols[2] ? cols[2].trim().replace('Rp', 'Rp ') : "";
    const priceStr = cols[3] ? cols[3].trim() : "0";
    const price = parseInt(priceStr, 10) || 0;
    const origin = cols[7] ? cols[7].trim() : "Unknown";
    
    const destination = title.includes(' - ') ? title.split(' - ')[0] : title;
    
    let csvImage = cols.length > 8 ? cols.slice(8).join(',').trim() : "";
    if (csvImage.startsWith('"') && csvImage.endsWith('"')) {
      csvImage = csvImage.substring(1, csvImage.length - 1);
    }
    
    // Find the matching image key
    const destLower = destination.toLowerCase();
    let image = defaultImage;
    
    if (csvImage && csvImage.startsWith('http')) {
      image = csvImage;
    } else {
      for (const key in imageMap) {
        if (destLower.includes(key)) {
          image = imageMap[key];
          break;
        }
      }
    }
    
    return {
      title,
      desc,
      dailyPrice,
      price,
      origin,
      destination,
      time: "Monday-Sunday",
      badge: index === 0 ? "Hot Deal" : (index === 1 ? "Best Seller" : ""),
      badgeColor: index === 0 ? "bg-red-500 text-white" : (index === 1 ? "bg-blue-500 text-white" : ""),
      image: image
    };
  });
} catch (error) {
  console.error("Failed to fetch packages:", error);
}
---

<Layout title="Featured Packages - DreamJourney">
    <main class="pt-20">
        <section id="packages" class="py-16 bg-gray-50">
            <div class="container mx-auto px-4">
                <div class="flex justify-between items-center mb-10">
                    <h2 class="text-3xl font-bold">🔥 Popular Packages This Week</h2>
                    <a href="#" class="text-primary font-semibold hover:underline">View All</a>
                </div>

                <!-- Filters -->
                <div id="package-filters" class="bg-white p-6 rounded-lg shadow-md mb-8 relative">
                    <!-- BUTTON RESET (Minimalist X button at top-right corner) -->
                    <button type="button" id="btn-reset-filter" title="Clear all filters" class="absolute top-3 right-3 text-gray-400 hover:text-red-500 bg-gray-50 hover:bg-red-50 p-1.5 rounded-full transition-all duration-200 cursor-pointer border border-transparent hover:border-red-100">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end pr-4">
                        <!-- 1. FILTER TIME RANGE -->
                        <div class="h-[76px] flex flex-col justify-between">
                            <label class="text-sm font-semibold text-gray-700">Time Range</label>
                            <select id="filter-time-range" class="filter-input w-full bg-gray-100 border border-transparent rounded-lg px-4 py-2.5 outline-none transition-all duration-200 text-sm">
                                <option value="">All Time Ranges</option>
                                <option value="Monday-Sunday">Daily</option>
                                <option value="Week 1-Week 4">Weekly</option>
                                <option value="30 day">Monthly</option>
                            </select>
                        </div>
                
                        <!-- 2. FILTER ORIGIN CITY -->
                        <div class="h-[76px] flex flex-col justify-between">
                            <label class="text-sm font-semibold text-gray-700">Origin City</label>
                            <select id="filter-kota-asal" class="filter-input w-full bg-gray-100 border border-transparent rounded-lg px-4 py-2.5 outline-none transition-all duration-200 text-sm">
                                <option value="">All Origins</option>
                                <option value="Jakarta">Jakarta</option>
                                <option value="Bandung">Bandung</option>
                                <option value="Surabaya">Surabaya</option>
                                <option value="Bali">Bali</option>
                                <option value="Semarang">Semarang</option>
                                <option value="Purwokerto">Purwokerto</option>
                                <option value="Medan">Medan</option>
                                <option value="Palembang">Palembang</option>
                                <option value="Banjarmasin">Banjarmasin</option>
                                <option value="Manado">Manado</option>
                                <option value="Makassar">Makassar</option>
                                <option value="Denpasar">Denpasar</option>
                            </select> 
                        </div>
                
                        <!-- 3. FILTER DESTINATION CITY -->
                        <div class="h-[76px] flex flex-col justify-between">
                            <label class="text-sm font-semibold text-gray-700">Destination City</label>
                            <input type="text" id="filter-kota-tujuan" list="rekomendasi-wisata" placeholder="Type destination city..." class="filter-input w-full bg-gray-100 border border-transparent rounded-lg px-4 py-2.5 outline-none transition-all duration-200 text-sm placeholder-gray-400">
                            <datalist id="rekomendasi-wisata">
                                <option value="Bali">
                                <option value="Lombok">
                                <option value="Labuan Bajo">
                                <option value="Raja Ampat">
                            </datalist>
                        </div>
                
                        <!-- 4. FILTER PRICE RANGE -->
                        <div class="h-[76px] flex flex-col justify-between bg-gray-100 border border-transparent rounded-lg p-3 transition-all duration-200 filter-box-range">
                            <div class="flex justify-between text-sm font-semibold text-gray-700 items-center">
                                <label>Price Range</label>
                                <span id="price-value" class="text-blue-600 font-bold text-xs">Rp 10.000</span>
                            </div>
                            <input type="range" id="filter-price-range" min="10000" max="10000000" step="10000" value="10000" class="w-full h-1.5 bg-gray-300 rounded-lg appearance-none cursor-pointer">
                            <div class="flex justify-between text-[10px] text-gray-500 leading-none">
                                <span>10.000</span>
                                <span>10.000.000</span>
                            </div>
                        </div>  
                    </div>
                </div>
                
                <!-- Package Grid -->
                <div id="packages-container" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                    {packages.map(pkg => (
                        <div class="package-item bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100" 
                             data-time={pkg.time} 
                             data-origin={pkg.origin} 
                             data-destination={pkg.destination} 
                             data-price={pkg.price}>
                            <div class="relative">
                                <img src={pkg.image} alt={pkg.destination} class="w-full h-48 object-cover">
                                {pkg.badge && (
                                    <span class={`absolute top-2 right-2 text-xs px-2 py-1 rounded-full font-medium ${pkg.badgeColor}`}>
                                        {pkg.badge}
                                    </span>
                                )}
                            </div>
                            <div class="p-5">
                                <h3 class="font-bold text-lg">{pkg.title}</h3>
                                <p class="text-gray-600 text-sm">{pkg.desc}</p>
                                <div class="my-4">
                                    <p class="text-gray-800 font-bold">{pkg.dailyPrice}/day</p>
                                    <p class="text-gray-600 text-sm">Total Price: Rp {pkg.price.toLocaleString('id-ID')}</p>
                                </div>
                                <button class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg font-semibold transition cursor-pointer start-saving-btn">
                                    Start Saving
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const filterTimeRange = document.getElementById('filter-time-range') as HTMLSelectElement;
        const filterOriginCity = document.getElementById('filter-kota-asal') as HTMLSelectElement;
        const filterDestCity = document.getElementById('filter-kota-tujuan') as HTMLInputElement;
        const priceSlider = document.getElementById('filter-price-range') as HTMLInputElement;
        
        const priceValueText = document.getElementById('price-value');
        const priceContainer = document.querySelector('.filter-box-range');
        const btnReset = document.getElementById('btn-reset-filter');
        
        const initialPrice = "10000";

        function filterPackages() {
            if (!filterTimeRange || !filterOriginCity || !filterDestCity || !priceSlider) return;
            const selectedTime = filterTimeRange.value;
            const selectedOrigin = filterOriginCity.value.toLowerCase().trim();
            const selectedDest = filterDestCity.value.toLowerCase().trim();
            const maxPrice = parseInt(priceSlider.value);

            const packageItems = document.querySelectorAll('.package-item') as NodeListOf<HTMLElement>;

            packageItems.forEach(item => {
                const itemTime = item.getAttribute('data-time') || "";
                const itemOrigin = (item.getAttribute('data-origin') || "").toLowerCase().trim();
                const itemDestination = (item.getAttribute('data-destination') || "").toLowerCase().trim();
                const itemPrice = parseInt(item.getAttribute('data-price') || "0");

                const matchesTime = (selectedTime === "" || itemTime === selectedTime);
                const matchesOrigin = (selectedOrigin === "" || itemOrigin === selectedOrigin);
                const matchesDest = (selectedDest === "" || itemDestination.includes(selectedDest));
                const matchesPrice = (maxPrice === parseInt(initialPrice) || itemPrice <= maxPrice);

                if (matchesTime && matchesOrigin && matchesDest && matchesPrice) {
                    item.classList.remove('hidden');
                } else {
                    item.classList.add('hidden');
                }
            });
        }

        function handleStyleChange(element: HTMLSelectElement | HTMLInputElement) {
            if (element.value !== "") {
                element.classList.remove('bg-gray-100', 'border-transparent');
                element.classList.add('bg-blue-50', 'border-blue-500', 'text-blue-700', 'font-medium');
            } else {
                element.classList.remove('bg-blue-50', 'border-blue-500', 'text-blue-700', 'font-medium');
                element.classList.add('bg-gray-100', 'border-transparent');
            }
            filterPackages();
        }

        if (filterTimeRange && filterOriginCity && filterDestCity && priceSlider) {
            const textInputs = [filterTimeRange, filterOriginCity, filterDestCity];
            textInputs.forEach(input => {
                input.addEventListener('input', () => handleStyleChange(input));
                input.addEventListener('change', () => handleStyleChange(input));
            });

            priceSlider.addEventListener('input', function () {
                let formattedValue = new Intl.NumberFormat('id-ID').format(parseInt(this.value));
                if (priceValueText) priceValueText.innerText = "Rp " + formattedValue;

                if (priceContainer) {
                    if (this.value !== initialPrice) {
                        priceContainer.classList.remove('bg-gray-100', 'border-transparent');
                        priceContainer.classList.add('bg-blue-50', 'border-blue-500');
                    } else {
                        priceContainer.classList.remove('bg-blue-50', 'border-blue-500');
                        priceContainer.classList.add('bg-gray-100', 'border-transparent');
                    }
                }
                filterPackages();
            });
        }

        if (btnReset) {
            btnReset.addEventListener('click', function() {
                const textInputs = [filterTimeRange, filterOriginCity, filterDestCity];
                textInputs.forEach(input => {
                    if (input) {
                        input.value = "";
                        handleStyleChange(input);
                    }
                });

                if (priceSlider) {
                    priceSlider.value = initialPrice;
                    let formattedPrice = new Intl.NumberFormat('id-ID').format(parseInt(initialPrice));
                    if (priceValueText) priceValueText.innerText = "Rp " + formattedPrice;
                }
                
                if (priceContainer) {
                    priceContainer.classList.remove('bg-blue-50', 'border-blue-500');
                    priceContainer.classList.add('bg-gray-100', 'border-transparent');
                }
                
                filterPackages();
            });
        }

        const saveButtons = document.querySelectorAll('.start-saving-btn');
        saveButtons.forEach(button => {
            button.addEventListener('click', () => {
                alert('Please login or sign up to start saving for this package!');
            });
        });
    });
</script>
