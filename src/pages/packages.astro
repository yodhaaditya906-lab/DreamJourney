---
import Layout from '../layouts/Layout.astro';

const { userId } = Astro.locals.auth();
const isLoggedIn = !!userId;

let packages = [];
try {
  const response = await fetch('https://docs.google.com/spreadsheets/d/1eD4zbqYsW-Ce6eLemIUt5VdSIykWnlhM0kwTVBgD1Yw/export?format=csv');
  const csvText = await response.text();
  
  const imageMap = {
    "bali": "https://images.unsplash.com/photo-1537996194471-e657df975ab4?q=80&w=600&auto=format&fit=crop",
    "jogja": "https://images.unsplash.com/photo-1626125345510-4603468eedfb?q=80&w=600&auto=format&fit=crop",
    "malioboro": "https://images.unsplash.com/photo-1626125345510-4603468eedfb?q=80&w=600&auto=format&fit=crop",
    "bandung": "https://images.unsplash.com/photo-1590559899147-eb54a69622df?q=80&w=600&auto=format&fit=crop",
    "puncak bogor": "https://images.unsplash.com/photo-1626082928503-4c91b5c4644d?q=80&w=600&auto=format&fit=crop",
    "malang": "https://images.unsplash.com/photo-1602167732001-97b7b137a1f5?q=80&w=600&auto=format&fit=crop",
    "gunung bromo": "https://images.unsplash.com/photo-1602167732001-97b7b137a1f5?q=80&w=600&auto=format&fit=crop",
    "surabaya": "https://images.unsplash.com/photo-1601999109332-542b18dbec57?q=80&w=600&auto=format&fit=crop",
    "pulau karimun jawa": "https://images.unsplash.com/photo-1516690561799-46d8f74f9abf?q=80&w=600&auto=format&fit=crop",
    "banda neira": "https://images.unsplash.com/photo-1516483638261-f4dbaf036963?q=80&w=600&auto=format&fit=crop",
    "raja ampat": "https://images.unsplash.com/photo-1544551763-46a013bb70d5?q=80&w=600&auto=format&fit=crop"
  };

  const defaultImage = "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=600&auto=format&fit=crop";

  function slugify(text) {
      if (!text) return '';
      return text.toString().toLowerCase()
        .replace(/\s+/g, '-')
        .replace(/[^\w\-]+/g, '')
        .replace(/\-\-+/g, '-')
        .replace(/^-+/, '')
        .replace(/-+$/, '');
  }

  function parseCSVRow(row) {
      const result = [];
      let curVal = '';
      let inQuotes = false;
      for (let i = 0; i < row.length; i++) {
          if (row[i] === '"') {
              inQuotes = !inQuotes;
          } else if (row[i] === ',' && !inQuotes) {
              result.push(curVal.trim());
              curVal = '';
          } else {
              curVal += row[i];
          }
      }
      result.push(curVal.trim());
      return result;
  }

  const rows = csvText.split('\n').slice(1);
  packages = rows.filter(row => row.trim() && !row.startsWith(',')).map((row, index) => {
    const cols = parseCSVRow(row);
    
    const title = cols[0] || "Unknown";
    const desc = cols[1] || "";
    const dailyPrice = cols[2] || "";
    const rawDailyPrice = cols[2] ? cols[2].replace(/[^\d]/g, '') : "0";
    const parsedDailyPrice = parseInt(rawDailyPrice, 10) || 0;
    const rawPrice = cols[3] ? cols[3].replace(/[^\d]/g, '') : "0";
    const price = parseInt(rawPrice, 10) || 0;
    const time = cols[4] || "";
    const origin = cols[5] || "Unknown";
    const destination = cols[6] || title;
    
    let mainImage = cols[11] || defaultImage;
    if (mainImage && mainImage.startsWith('"')) mainImage = mainImage.substring(1, mainImage.length-1);
    
    const priceAkomodasi = parseInt(cols[16] ? cols[16].replace(/[^\d]/g, '') : "0", 10) || 0;
    const priceTransport = parseInt(cols[17] ? cols[17].replace(/[^\d]/g, '') : "0", 10) || 0;
    const priceWahana = parseInt(cols[18] ? cols[18].replace(/[^\d]/g, '') : "0", 10) || 0;
    const priceLainnya = parseInt(cols[19] ? cols[19].replace(/[^\d]/g, '') : "0", 10) || 0;
    
    return {
      title,
      slug: slugify(title),
      desc,
      dailyPrice,
      parsedDailyPrice,
      price,
      origin,
      destination,
      time,
      badge: index === 0 ? "Hot Deal" : (index === 1 ? "Best Seller" : ""),
      badgeColor: index === 0 ? "bg-red-500 text-white" : (index === 1 ? "bg-blue-500 text-white" : ""),
      image: mainImage,
      priceAkomodasi,
      priceTransport,
      priceWahana,
      priceLainnya
    };
  });
} catch (error) {
  console.error("Failed to fetch packages:", error);
}
---

<Layout title="Featured Packages - DreamJourney">
    <main class="pt-20" data-is-logged-in={isLoggedIn ? 'true' : 'false'}>
        <section class="relative py-16 bg-cover bg-center" style="background-image: url('/images/bromo_hero_bg.png');">
            <!-- Overlay -->
            <div class="absolute inset-0" style="background-color: rgba(0,0,0,0.4);"></div>
            
            <div class="container mx-auto px-4 relative z-10">
                <div class="max-w-5xl mx-auto">
                    <h1 class="text-2xl md:text-3xl font-bold text-white mb-6 md:mb-8 text-center drop-shadow-md">Temukan Paket Perjalanan Terbaik</h1>
                    
                    <!-- Filters -->
                    <div id="package-filters" class="glass-card p-4 md:p-6 rounded-2xl relative">
                    <!-- BUTTON RESET (Minimalist X button at top-right corner) -->
                    <button type="button" id="btn-reset-filter" title="Clear all filters" class="tap-active absolute top-3 right-3 text-gray-400 hover:text-red-500 bg-white/50 hover:bg-red-50 p-2 rounded-full transition-all duration-200 cursor-pointer border border-transparent hover:border-red-100 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 items-end pr-0 md:pr-4 mt-2">
                        <!-- 1. FILTER ORIGIN CITY -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-xs md:text-sm font-semibold text-gray-700 ml-1">Kota Asal</label>
                            <select id="filter-kota-asal" class="filter-input w-full bg-white/80 border border-white/50 rounded-xl px-4 py-2.5 outline-none transition-smooth text-xs md:text-sm shadow-sm focus:ring-2 focus:ring-primary/20">
                                <option value="">Semua Kota Asal</option>
                                <option value="Jakarta">Jakarta</option>
                                <option value="Bandung">Bandung</option>
                                <option value="Surabaya">Surabaya</option>
                                <option value="Bali">Bali</option>
                                <option value="Semarang">Semarang</option>
                                <option value="Purwokerto">Purwokerto</option>
                                <option value="Medan">Medan</option>
                                <option value="Palembang">Palembang</option>
                                <option value="Banjarmasin">Banjarmasin</option>
                                <option value="Manado">Manado</option>
                                <option value="Makassar">Makassar</option>
                                <option value="Denpasar">Denpasar</option>
                            </select> 
                        </div>
                
                        <!-- 3. FILTER DESTINATION CITY -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-xs md:text-sm font-semibold text-gray-700 ml-1">Kota Tujuan</label>
                            <input type="text" id="filter-kota-tujuan" list="rekomendasi-wisata" placeholder="Ketik kota tujuan..." class="filter-input w-full bg-white/80 border border-white/50 rounded-xl px-4 py-2.5 outline-none transition-smooth text-xs md:text-sm placeholder-gray-400 shadow-sm focus:ring-2 focus:ring-primary/20">
                            <datalist id="rekomendasi-wisata">
                                <option value="Bali">
                                <option value="Lombok">
                                <option value="Labuan Bajo">
                                <option value="Raja Ampat">
                            </datalist>
                        </div>
                
                        <!-- 4. FILTER ESTIMASI BUDGET -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-xs md:text-sm font-semibold text-gray-700 ml-1">Estimasi Budget (Rp)</label>
                            <input type="text" inputmode="numeric" id="filter-price-input" placeholder="Ketik nominal budget..." class="filter-input w-full bg-white/80 border border-white/50 rounded-xl px-4 py-2.5 outline-none transition-smooth text-xs md:text-sm placeholder-gray-400 shadow-sm focus:ring-2 focus:ring-primary/20">
                        </div>
                        
                        <!-- 5. FILTER TIPE TABUNGAN -->
                        <div class="flex flex-col gap-1.5">
                            <label class="text-xs md:text-sm font-semibold text-gray-700 ml-1">Tipe Tabungan</label>
                            <select id="filter-tipe-tabungan" class="filter-input w-full bg-white/80 border border-white/50 rounded-xl px-4 py-2.5 outline-none transition-smooth text-xs md:text-sm shadow-sm focus:ring-2 focus:ring-primary/20">
                                <option value="1">Harian (/hari)</option>
                                <option value="7">Mingguan (/minggu)</option>
                                <option value="30">Bulanan (/bulan)</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="packages" class="py-12 bg-gray-50 min-h-screen">
            <div class="container mx-auto px-4">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 sm:gap-0 mb-6 md:mb-8">
                    <h2 class="text-xl md:text-2xl font-bold text-gray-800">🔥 Paket Populer Minggu Ini</h2>
                    <a href="#" class="text-primary font-semibold hover:underline text-sm md:text-base">Lihat Semua</a>
                </div>
                
                <!-- Package Grid -->
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-3 sm:gap-4 w-full">
                    <span class="text-gray-600 bg-white px-4 py-2 rounded-lg shadow-sm border border-gray-200 text-xs md:text-sm w-full sm:w-auto text-center sm:text-left">Menampilkan {packages.length} paket</span>
                    <select id="sort-price" class="bg-white w-full sm:w-auto px-3 py-2 rounded-lg shadow-sm border border-gray-200 text-xs md:text-sm font-semibold text-gray-700 cursor-pointer outline-none hover:bg-gray-50 transition">
                        <option value="">Urutkan: Paling Relevan</option>
                        <option value="asc">Harga Terendah - Tertinggi</option>
                        <option value="desc">Harga Tertinggi - Terendah</option>
                    </select>
                </div>

                <div id="packages-container" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                    {packages.map((pkg, index) => (
                        <div class="package-item bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 flex flex-col" 
                             data-index={index}
                             data-time={pkg.time} 
                             data-origin={pkg.origin} 
                             data-destination={pkg.destination} 
                             data-price={pkg.price}
                             data-title={pkg.title}
                             data-daily-price={pkg.parsedDailyPrice}
                             data-akomodasi={pkg.priceAkomodasi}
                             data-transport={pkg.priceTransport}
                             data-wahana={pkg.priceWahana}
                             data-lainnya={pkg.priceLainnya}>
                            <a href={`/package/${pkg.slug}`} class="block flex-grow cursor-pointer">
                                <div class="relative">
                                    <img src={pkg.image} alt={pkg.destination} class="w-full h-48 object-cover">
                                    {pkg.badge && (
                                        <span class={`absolute top-2 right-2 text-xs px-2 py-1 rounded-full font-medium ${pkg.badgeColor}`}>
                                            {pkg.badge}
                                        </span>
                                    )}
                                </div>
                                <div class="p-4 pb-0 flex-grow">
                                    <h3 class="font-bold text-base md:text-lg text-gray-900 leading-tight mb-1">{pkg.title}</h3>
                                    <p class="text-gray-500 text-xs md:text-sm line-clamp-2">{pkg.desc}</p>
                                    <div class="mt-3 mb-2 bg-indigo-50/50 p-2.5 rounded-lg border border-indigo-100/50">
                                        <p class="text-primary font-bold text-lg md:text-xl price-display-text">{pkg.dailyPrice}<span class="text-xs font-medium text-gray-500">/hari</span></p>
                                        <p class="text-gray-500 text-xs mt-0.5 font-medium">Total: Rp {pkg.price.toLocaleString('id-ID')}</p>
                                    </div>
                                </div>
                            </a>
                            <div class="p-4 pt-2">
                                <button class="w-full bg-primary hover:bg-primary-dark text-white py-2.5 rounded-lg font-bold text-sm md:text-base transition cursor-pointer start-saving-btn mt-auto">
                                    Mulai Menabung
                                </button>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const filterOriginCity = document.getElementById('filter-kota-asal') as HTMLSelectElement;
        const filterDestCity = document.getElementById('filter-kota-tujuan') as HTMLInputElement;
        const priceInput = document.getElementById('filter-price-input') as HTMLInputElement;
        const tipeTabungan = document.getElementById('filter-tipe-tabungan') as HTMLSelectElement;
        const sortSelect = document.getElementById('sort-price') as HTMLSelectElement;
        
        const btnReset = document.getElementById('btn-reset-filter');

        function filterPackages() {
            if (!filterOriginCity || !filterDestCity || !priceInput) return;
            const selectedOrigin = filterOriginCity.value.toLowerCase().trim();
            const selectedDest = filterDestCity.value.toLowerCase().trim();
            const rawPriceInput = priceInput.value.replace(/[^\d]/g, '');
            const targetPrice = parseInt(rawPriceInput);
            const tabunganMultiplier = tipeTabungan ? parseInt(tipeTabungan.value) || 1 : 1;
            const sortMode = sortSelect ? sortSelect.value : "";

            const packageItems = document.querySelectorAll('.package-item') as NodeListOf<HTMLElement>;

            packageItems.forEach(item => {
                const itemOrigin = (item.getAttribute('data-origin') || "").toLowerCase().trim();
                const itemDestination = (item.getAttribute('data-destination') || "").toLowerCase().trim();
                
                const baseDailyPrice = parseInt(item.getAttribute('data-daily-price') || "0");
                const itemDailyPrice = baseDailyPrice * tabunganMultiplier;
                
                const priceTextEl = item.querySelector('.price-display-text');
                if (priceTextEl) {
                    const suffix = tabunganMultiplier === 1 ? '/hari' : (tabunganMultiplier === 7 ? '/minggu' : '/bulan');
                    const formatted = new Intl.NumberFormat('id-ID').format(itemDailyPrice);
                    priceTextEl.textContent = `Rp ${formatted}${suffix}`;
                }

                const matchesOrigin = (selectedOrigin === "" || itemOrigin === selectedOrigin);
                const matchesDest = (selectedDest === "" || itemDestination.includes(selectedDest));
                
                let matchesPrice = true;
                if (!isNaN(targetPrice) && targetPrice > 0) {
                    const minPrice = targetPrice * 0.5;
                    const maxPrice = targetPrice * 1.5;
                    matchesPrice = itemDailyPrice >= minPrice && itemDailyPrice <= maxPrice;
                }

                if (matchesOrigin && matchesDest && matchesPrice) {
                    item.classList.remove('hidden');
                } else {
                    item.classList.add('hidden');
                }
            });

            const container = document.getElementById('packages-container');
            if (container) {
                const itemsArray = Array.from(packageItems);
                if (sortMode === "asc") {
                    itemsArray.sort((a, b) => {
                        const priceA = parseInt(a.getAttribute('data-daily-price') || "0");
                        const priceB = parseInt(b.getAttribute('data-daily-price') || "0");
                        return priceA - priceB;
                    });
                } else if (sortMode === "desc") {
                    itemsArray.sort((a, b) => {
                        const priceA = parseInt(a.getAttribute('data-daily-price') || "0");
                        const priceB = parseInt(b.getAttribute('data-daily-price') || "0");
                        return priceB - priceA;
                    });
                } else if (!isNaN(targetPrice) && targetPrice > 0) {
                    itemsArray.sort((a, b) => {
                        const basePriceA = parseInt(a.getAttribute('data-daily-price') || "0");
                        const basePriceB = parseInt(b.getAttribute('data-daily-price') || "0");
                        const priceA = basePriceA * tabunganMultiplier;
                        const priceB = basePriceB * tabunganMultiplier;
                        return Math.abs(priceA - targetPrice) - Math.abs(priceB - targetPrice);
                    });
                } else {
                    itemsArray.sort((a, b) => {
                        const idxA = parseInt(a.getAttribute('data-index') || "0");
                        const idxB = parseInt(b.getAttribute('data-index') || "0");
                        return idxA - idxB;
                    });
                }
                itemsArray.forEach(item => container.appendChild(item));
            }
        }

        function handleStyleChange(element: HTMLSelectElement | HTMLInputElement) {
            if (element.value !== "") {
                element.classList.remove('bg-gray-100', 'border-transparent');
                element.classList.add('bg-blue-50', 'border-blue-500', 'text-blue-700', 'font-medium');
            } else {
                element.classList.remove('bg-blue-50', 'border-blue-500', 'text-blue-700', 'font-medium');
                element.classList.add('bg-gray-100', 'border-transparent');
            }
            filterPackages();
        }

        if (filterOriginCity && filterDestCity && priceInput && tipeTabungan) {
            const textInputs = [filterOriginCity, filterDestCity, priceInput, tipeTabungan];
            if (sortSelect) textInputs.push(sortSelect);
            textInputs.forEach(input => {
                input.addEventListener('input', function() {
                    if (this === priceInput) {
                        const rawValue = this.value.replace(/[^\d]/g, '');
                        if (rawValue) {
                            this.value = new Intl.NumberFormat('en-US').format(parseInt(rawValue));
                        } else {
                            this.value = '';
                        }
                    }
                    handleStyleChange(this);
                });
                input.addEventListener('change', function() {
                    handleStyleChange(this);
                });
            });
        }

        if (btnReset) {
            btnReset.addEventListener('click', function() {
                const textInputs = [filterOriginCity, filterDestCity, priceInput, tipeTabungan];
                if (sortSelect) textInputs.push(sortSelect);
                textInputs.forEach(input => {
                    if (input) {
                        input.value = "";
                        handleStyleChange(input);
                    }
                });
                filterPackages();
            });
        }
        const startSavingBtns = document.querySelectorAll('.start-saving-btn');
        startSavingBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                
                const mainEl = document.querySelector('main');
                const isLoggedIn = mainEl?.getAttribute('data-is-logged-in') === 'true';
                if (!isLoggedIn) {
                    const modal = document.getElementById('custom-login-modal');
                    if (modal) modal.classList.remove('hidden');
                    return;
                }

                const item = (e.target as HTMLElement).closest('.package-item');
                if (!item) return;
                
                const title = item.getAttribute('data-title') || '';
                const price = item.getAttribute('data-price') || '0';
                const dailyPrice = item.getAttribute('data-daily-price') || '0';
                const time = item.getAttribute('data-time') || '';

                const ak = parseInt(item.getAttribute('data-akomodasi') || '0');
                const tr = parseInt(item.getAttribute('data-transport') || '0');
                const wh = parseInt(item.getAttribute('data-wahana') || '0');
                const ln = parseInt(item.getAttribute('data-lainnya') || '0');
                const hasCustomBreakdown = (ak + tr + wh + ln) > 0;
                
                const imgEl = item.querySelector('img');
                const image = imgEl ? imgEl.getAttribute('src') : '';
                
                const query = new URLSearchParams({
                    title, price, dailyPrice, time, image: image || '',
                    akomodasi: (hasCustomBreakdown ? ak : parseInt(price) * 0.45).toString(),
                    transport: (hasCustomBreakdown ? tr : 0).toString(),
                    wahana: (hasCustomBreakdown ? wh : parseInt(price) * 0.30).toString(),
                    lainnya: (hasCustomBreakdown ? ln : parseInt(price) * 0.25).toString()
                }).toString();
                
                window.location.href = `/setup-saving?${query}`;
            });
        });
    });
</script>
