---
import Layout from '../layouts/Layout.astro';

const { userId } = Astro.locals.auth();

if (!userId) {
    return Astro.redirect('/');
}

// Optionally, we could check if they already have all the info and redirect them away, 
// but we'll handle this purely in the client or allow them to update it if they access this page.
---

<Layout title="Lengkapi Profil - DreamJourney">
    <main class="min-h-screen bg-gray-50 flex flex-col justify-center items-center py-12 px-4 sm:px-6 lg:px-8">
        
        <div class="max-w-md w-full bg-white rounded-2xl shadow-xl overflow-hidden">
            <div class="bg-primary px-6 py-8 text-center">
                <div class="mx-auto w-16 h-16 bg-white/20 rounded-full flex items-center justify-center mb-4 backdrop-blur-sm">
                    <span class="text-3xl">👋</span>
                </div>
                <h2 class="text-2xl font-bold text-white">Lengkapi Profil Anda</h2>
                <p class="text-primary-100 mt-2 text-sm">Tinggal selangkah lagi untuk mulai merencanakan liburan impian dan menabung bersama DreamJourney!</p>
            </div>
            
            <div class="p-8">
                <form id="onboarding-form" class="space-y-6">
                    <!-- Error Alert -->
                    <div id="error-alert" class="hidden bg-red-50 text-red-600 p-4 rounded-lg text-sm font-medium border border-red-100">
                    </div>

                    <div>
                        <label for="username" class="block text-sm font-semibold text-gray-700">Username</label>
                        <p class="text-xs text-gray-500 mb-2">Nama panggilan Anda di DreamJourney</p>
                        <input type="text" name="username" id="username" required minlength="3" placeholder="Contoh: travelholic99" 
                            class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition">
                        <p id="username-status" class="text-xs mt-2 font-medium hidden"></p>
                    </div>

                    <div>
                        <label for="domisili" class="block text-sm font-semibold text-gray-700">Domisili Kota</label>
                        <p class="text-xs text-gray-500 mb-2">Pilih kota tempat Anda tinggal saat ini</p>
                        <input type="text" name="domisili" id="domisili" required placeholder="Contoh: Jakarta Selatan" 
                            class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition">
                    </div>

                    <div>
                        <label for="dob" class="block text-sm font-semibold text-gray-700">Tanggal Lahir</label>
                        <p class="text-xs text-gray-500 mb-2">Data ini diperlukan untuk validasi layanan keamanan tabungan</p>
                        <input type="date" name="dob" id="dob" required 
                            class="appearance-none block w-full px-4 py-3 border border-gray-300 rounded-xl text-gray-700 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition">
                    </div>

                    <div class="pt-2">
                        <button type="submit" id="submit-btn" class="w-full flex justify-center py-3.5 px-4 border border-transparent rounded-xl shadow-sm text-sm font-bold text-white bg-primary hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all cursor-pointer">
                            Simpan & Mulai Menabung
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
    </main>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('onboarding-form') as HTMLFormElement;
        const btn = document.getElementById('submit-btn') as HTMLButtonElement;
        const errorAlert = document.getElementById('error-alert') as HTMLDivElement;
        const usernameInput = document.getElementById('username') as HTMLInputElement;
        const usernameStatus = document.getElementById('username-status') as HTMLParagraphElement;
        
        let isUsernameValid = false;
        let usernameTimeout: any;

        // Coba isi otomatis jika data sudah ada
        const attemptPrefill = () => {
            if (window.Clerk && window.Clerk.user) {
                const user = window.Clerk.user;
                if (user.username && !usernameInput.value) {
                    usernameInput.value = user.username;
                    checkUsername(user.username); // validasi username bawaan
                }
                if (user.unsafeMetadata?.domisili) {
                    (document.getElementById('domisili') as HTMLInputElement).value = user.unsafeMetadata.domisili as string;
                }
                if (user.unsafeMetadata?.dob) {
                    (document.getElementById('dob') as HTMLInputElement).value = user.unsafeMetadata.dob as string;
                }
            } else {
                setTimeout(attemptPrefill, 500); // retry
            }
        };
        attemptPrefill();

        const checkUsername = async (username: string) => {
            if (username.length < 3) {
                usernameStatus.classList.add('hidden');
                isUsernameValid = false;
                return;
            }

            usernameStatus.classList.remove('hidden');
            usernameStatus.className = 'text-xs mt-2 font-medium text-gray-500';
            usernameStatus.innerText = 'Mengecek ketersediaan...';
            isUsernameValid = false;

            try {
                const res = await fetch(`/api/check-username?username=${encodeURIComponent(username)}`);
                const data = await res.json();

                if (res.ok && data.isAvailable) {
                    usernameStatus.className = 'text-xs mt-2 font-medium text-green-600';
                    usernameStatus.innerText = '✅ Username tersedia!';
                    isUsernameValid = true;
                } else if (res.ok && !data.isAvailable) {
                    usernameStatus.className = 'text-xs mt-2 font-medium text-red-600';
                    usernameStatus.innerText = '❌ Username sudah terpakai, pilih yang lain.';
                    isUsernameValid = false;
                } else {
                    usernameStatus.className = 'text-xs mt-2 font-medium text-red-600';
                    usernameStatus.innerText = 'Gagal mengecek username.';
                }
            } catch (err) {
                usernameStatus.className = 'text-xs mt-2 font-medium text-red-600';
                usernameStatus.innerText = 'Kesalahan jaringan.';
            }
        };

        usernameInput.addEventListener('input', (e) => {
            const val = (e.target as HTMLInputElement).value.trim();
            clearTimeout(usernameTimeout);
            usernameTimeout = setTimeout(() => {
                checkUsername(val);
            }, 600);
        });

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (!isUsernameValid) {
                errorAlert.innerText = "Silakan gunakan username yang tersedia sebelum melanjutkan.";
                errorAlert.classList.remove('hidden');
                return;
            }
            
            const username = (document.getElementById('username') as HTMLInputElement).value;
            const domisili = (document.getElementById('domisili') as HTMLInputElement).value;
            const dob = (document.getElementById('dob') as HTMLInputElement).value;
            
            errorAlert.classList.add('hidden');
            const originalText = btn.innerHTML;
            btn.innerHTML = 'Menyimpan...';
            btn.disabled = true;
            btn.classList.add('opacity-70');
            
            try {
                if (!window.Clerk || !window.Clerk.user) {
                    throw new Error("Sistem belum siap. Pastikan Anda terhubung ke internet.");
                }
                
                // Update username & metadata di Clerk
                await window.Clerk.user.update({
                    username: username,
                    unsafeMetadata: {
                        domisili: domisili,
                        dob: dob
                    }
                });

                // Simpan juga ke Supabase untuk pengecekan username unik di masa depan
                const saveRes = await fetch('/api/save-user', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        userId: window.Clerk.user.id,
                        username: username,
                        domisili: domisili,
                        dob: dob
                    })
                });

                if (!saveRes.ok) {
                    console.warn("Peringatan: Gagal mensinkronkan data ke Supabase, namun profil Clerk berhasil.");
                }
                
                // Berhasil!
                btn.innerHTML = 'Berhasil! Mengarahkan...';
                
                // Tunggu sebentar lalu redirect ke dashboard
                setTimeout(() => {
                    const urlParams = new URLSearchParams(window.location.search);
                    const redirectUrl = urlParams.get('redirect_url') || '/dashboard';
                    window.location.href = redirectUrl;
                }, 1000);
                
            } catch (error: any) {
                console.error(error);
                const errMsg = error.errors?.[0]?.message || error.message || "Terjadi kesalahan saat menyimpan data.";
                
                // Jika error dari Clerk tentang username
                if (errMsg.toLowerCase().includes('username')) {
                    usernameStatus.className = 'text-xs mt-2 font-medium text-red-600';
                    usernameStatus.innerText = '❌ ' + errMsg;
                    isUsernameValid = false;
                    errorAlert.classList.add('hidden'); // Sembunyikan alert atas agar tidak dobel
                } else {
                    errorAlert.innerText = errMsg;
                    errorAlert.classList.remove('hidden');
                }
                
                btn.innerHTML = originalText;
                btn.disabled = false;
                btn.classList.remove('opacity-70');
            }
        });
    });
</script>
