---
---
<footer class="bg-gray-950 text-gray-300 pt-16 pb-24 md:pb-12 border-t border-gray-900">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
            <!-- Brand & Info -->
            <div class="space-y-4">
                <a href="/" class="flex items-center gap-2 text-2xl font-bold text-white">
                    <i data-feather="briefcase" class="text-primary w-6 h-6"></i>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">DreamJourney</span>
                </a>
                <p class="text-gray-400 text-sm leading-relaxed">
                    Travel Now, Pay Smart. Plan and secure your dream vacation with our flexible, interest-free savings tracker or fast holiday loan packages.
                </p>
                <!-- OJK Sign -->
                <div class="flex items-center gap-2 pt-2 text-xs text-emerald-400">
                    <i data-feather="award" class="w-4 h-4"></i>
                    <span>Registered & Supervised by OJK (Otoritas Jasa Keuangan)</span>
                </div>
            </div>

            <!-- Quick Navigation -->
            <div class="space-y-4">
                <h4 class="text-white font-bold text-base tracking-wide uppercase">Quick Links</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="/" class="hover:text-primary transition duration-150">Home Page</a></li>
                    <li><a href="/packages" class="hover:text-primary transition duration-150">Featured Packages</a></li>
                    <li><a href="/planner" class="hover:text-primary transition duration-150">Trip Planner</a></li>
                    <li><a href="/community" class="hover:text-primary transition duration-150">Travel Community</a></li>
                </ul>
            </div>

            <!-- Services & Financing -->
            <div class="space-y-4">
                <h4 class="text-white font-bold text-base tracking-wide uppercase">Services</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="/dashboard" class="hover:text-primary transition duration-150">Savings Tracker Dashboard</a></li>
                    <li><a href="/loan" class="hover:text-primary transition duration-150">Instant Holiday Loan</a></li>
                    <li><a href="/design-trip" class="hover:text-primary transition duration-150">Custom Trip Designer</a></li>
                    <li><a href="#" class="hover:text-primary transition duration-150">Corporate Trip Travel Partners</a></li>
                </ul>
            </div>

            <!-- Trust & Encryption -->
            <div class="space-y-4">
                <h4 class="text-white font-bold text-base tracking-wide uppercase">Security & Connect</h4>
                <p class="text-gray-400 text-sm leading-relaxed">
                    Your transactions are secured with military-grade 256-bit SSL encryption.
                </p>
                <div class="flex gap-4 pt-2">
                    <a href="#" class="bg-gray-900 hover:bg-primary hover:text-white p-2.5 rounded-full transition duration-200" aria-label="Facebook">
                        <i data-feather="facebook" class="w-4 h-4"></i>
                    </a>
                    <a href="#" class="bg-gray-900 hover:bg-primary hover:text-white p-2.5 rounded-full transition duration-200" aria-label="Instagram">
                        <i data-feather="instagram" class="w-4 h-4"></i>
                    </a>
                    <a href="#" class="bg-gray-900 hover:bg-primary hover:text-white p-2.5 rounded-full transition duration-200" aria-label="Twitter">
                        <i data-feather="twitter" class="w-4 h-4"></i>
                    </a>
                    <a href="#" class="bg-gray-900 hover:bg-primary hover:text-white p-2.5 rounded-full transition duration-200" aria-label="Linkedin">
                        <i data-feather="linkedin" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>
        </div>

        <hr class="border-gray-900 my-8">

        <!-- Bottom Copyright -->
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500 text-center md:text-left">
            <div>
                &copy; {new Date().getFullYear()} DreamJourney. All rights reserved.
            </div>
            <div class="flex gap-6">
                <a href="#" class="hover:text-gray-400">Privacy Policy</a>
                <a href="#" class="hover:text-gray-400">Terms of Use</a>
                <a href="#" class="hover:text-gray-400">Contact Support</a>
            </div>
        </div>
    </div>
</footer>
